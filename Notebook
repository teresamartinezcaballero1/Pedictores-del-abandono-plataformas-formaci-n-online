    "        f'{f1_rl:.4f}',\n",
    "        f'{auc_rl:.4f}',\n",
    "        f'{precision_rl*100:.1f}%',\n",
    "        f'{recall_rl*100:.1f}%',\n",
    "        str(fp_rl),\n",
    "        str(fn_rl)\n",
    "    ],\n",
    "    'Random Forest': [\n",
    "        f'{acc_rf*100:.2f}%',\n",
    "        f'{f1_rf:.4f}',\n",
    "        f'{auc_rf:.4f}',\n",
    "        f'{precision_rf*100:.1f}%',\n",
    "        f'{recall_rf*100:.1f}%',\n",
    "        str(fp_rf),\n",
    "        str(fn_rf)\n",
    "    ],\n",
    "    # Random Forest gana en todas las métricas\n",
    "    # la columna lo documenta explícitamente para el lector\n",
    "    'Mejor modelo': [' Random Forest'] * 7\n",
    "})\n",
