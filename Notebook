    "# muestra si los grupos encontrados por K-Means tienen tasas de abandono distintas entre sí.\n",
    "# Si todos los clusters tuvieran la misma tasa de abandono el clustering no aportaría valor para predecir el riesgo.\n",
    "# Si las tasas son muy distintas confirma que K-Means ha  encontrado grupos con perfiles de riesgo diferenciados.\n",
    "print('\\nTASA DE ABANDONO POR CLUSTER')\n",
    "print('=' * 50)\n",
    "tasa = base.groupby('cluster')['target_withdrawal'].mean()\n",
    "for cluster, tasa_val in tasa.items():\n",
