    "             fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Importancia relativa')\n",
    "\n",
    "# invert_yaxis--> pone la variable más importante arriba sin esto la más importante quedaría abajo\n",
    "ax.invert_yaxis()\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_importance_rf.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print('\\nRandom Forest completado ')\n",
    "print('Gráficos: confusion_rf, roc_comparacion, importance_rf')"
   ]
