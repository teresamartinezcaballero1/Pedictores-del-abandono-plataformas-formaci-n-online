    "# ============================================================\n",
    "# CELDA 14b — Análisis y tratamiento de outliers\n",
    "# ============================================================\n",
    "\n",
    "# Variables numéricas continuas a analizar\n",
    "# Se excluyen binarias porque el concepto de outlier no aplica — solo pueden valer 0 o 1\n",
    "# Se excluyen variables centinela porque ese -1 no es un valor real sino un marcador\n",
    "vars_outliers = ['total_clicks', 'active_days', 'avg_score',\n",
    "                 'num_assessments_submitted', 'avg_submission_delay']\n",
    "\n",
    "# --- PASO 1: Detección de outliers con método IQR ---\n",
    "#Es el método estándar para detectar outliers. \n",
    "#No asume distribución normal por eso es más robusto que usar la desviación típica.\n",
    "# IQR = Q3 - Q1\n",
    "# Outlier si valor < Q1 - 1.5*IQR  O  valor > Q3 + 1.5*IQR\n",
    "print('=' * 60)\n",
    "print('DETECCIÓN DE OUTLIERS — MÉTODO IQR')\n",
    "print('=' * 60)\n",
    "\n",
    "# Lista vacía donde se irán guardando los resultados de cada variable\n",
    "resumen_outliers = []\n",
    "\n",
    "for var in vars_outliers:\n",
    "    serie = base[var]\n",
    "    # Q1 = percentil 25 → el 25% de los valores están por debajo\n",
    "    Q1  = serie.quantile(0.25)\n",
    "    # Q3 = percentil 75 → el 75% de los valores están por debajo\n",
    "    Q3  = serie.quantile(0.75)\n",
    "    # IQR = distancia entre Q1 y Q3 → mide la dispersión central de los datos\n",
    "    IQR = Q3 - Q1\n",
    "    # Límites del rango válido — valores fuera de este rango son outliers\n",
    "    lim_inf = Q1 - 1.5 * IQR\n",
    "    lim_sup = Q3 + 1.5 * IQR\n",
    "\n",
    "    #Filtra los estudiantes cuyos valores están fuera del rango válido.\n",
    "    # | significa OR — es outlier si está por debajo del límite inferior\n",
    "    # O por encima del límite superior\n",
    "    outliers = base[(serie < lim_inf) | (serie > lim_sup)]\n",
    "    n_out = len(outliers)\n",
    "    pct   = n_out / len(base) * 100\n",
    "\n",
    "    # Guarda los resultados de esta variable en la lista\n",
    "    resumen_outliers.append({\n",
    "        'Variable': var,\n",
    "        'Q1': round(Q1, 2),\n",
    "        'Q3': round(Q3, 2),\n",
    "        'IQR': round(IQR, 2),\n",
    "        'Límite inf': round(lim_inf, 2),\n",
    "        'Límite sup': round(lim_sup, 2),\n",
    "        'N outliers': n_out,\n",
    "        '% outliers': round(pct, 2)\n",
    "    })\n",
    "\n",
    "    print(f'{var}:')\n",
    "    print(f'  Rango válido: [{lim_inf:.2f}, {lim_sup:.2f}]')\n",
    "    print(f'  Outliers detectados: {n_out} ({pct:.2f}%)')\n",
    "    print()\n",
    "    \n",
    "# Convierte la lista de resultados en una tabla para visualizarla mejor\n",
    "df_resumen = pd.DataFrame(resumen_outliers)\n",
    "\n",
    "# --- GRÁFICO 1: Boxplots de las variables numéricas clave ---\n",
    "# Un boxplot muestra la distribución de los valores y los outliers visualmente\n",
    "# Se crea un subgráfico por cada variable a analizar\n",
    "fig, axes = plt.subplots(1, len(vars_outliers), figsize=(18, 6))\n",
    "\n",
    "for ax, var in zip(axes, vars_outliers):\n",
    "    # Se recalculan los límites IQR para cada variable\n",
    "    # para poder mostrar el número de outliers en el título\n",
    "    Q1  = base[var].quantile(0.25)\n",
    "    Q3  = base[var].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lim_inf = Q1 - 1.5 * IQR\n",
    "    lim_sup = Q3 + 1.5 * IQR\n",
    "\n",
    " # .dropna() elimina los nulos antes de dibujar\n",
    "    # patch_artist=True permite colorear el interior de la caja\n",
    "    # medianprops: color y grosor de la línea de la mediana\n",
    "    # boxprops: color de relleno de la caja\n",
    "    # whiskerprops: color de las líneas que salen de la caja\n",
    "    # capprops: color de las líneas horizontales en los extremos\n",
    "    # flierprops: estilo de los puntos que representan los outliers\n",
    "    ax.boxplot(base[var].dropna(),\n",
    "               patch_artist=True,\n",
    "               medianprops={'color': 'white', 'linewidth': 2},\n",
    "               boxprops={'facecolor': 'steelblue', 'alpha': 0.7},\n",
    "               whiskerprops={'color': 'steelblue'},\n",
    "               capprops={'color': 'steelblue'},\n",
    "               flierprops={'marker': 'o',\n",
    "                           'markerfacecolor': 'tomato',\n",
    "                           'markersize': 3,\n",
    "                           'alpha': 0.5})\n",
    "    # Cuenta los outliers de esta variable para ponerlo en el título\n",
    "    n_out = len(base[(base[var] < lim_inf) | (base[var] > lim_sup)])\n",
    "    pct   = n_out / len(base) * 100\n",
    "    # Título con el nombre de la variable y el número de outliers\n",
    "    ax.set_title(f'{var}\\n({n_out} outliers, {pct:.1f}%)',\n",
    "                 fontsize=10, fontweight='bold')\n",
    "    # Elimina las etiquetas del eje X porque no aportan información\n",
    "    ax.set_xticks([])\n",
    "\n",
    "plt.suptitle('Distribución y outliers — variables numéricas clave',\n",
    "             fontsize=13, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_outliers_boxplot.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# --- GRÁFICO 2: Resumen cuantitativo de outliers ---\n",
    "# Muestra el porcentaje de outliers de cada variable en un gráfico de barras\n",
    "# para comparar fácilmente qué variables tienen más valores extremos\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "\n",
    "variables   = df_resumen['Variable']\n",
    "porcentajes = df_resumen['% outliers']\n",
    "numeros     = df_resumen['N outliers']\n",
    "\n",
    "# edgecolor='none' elimina el reborde negro de las barras\n",
    "# alpha=0.8 hace las barras ligeramente transparentes\n",
    "bars = ax.bar(variables, porcentajes,\n",
    "              color='steelblue', alpha=0.8, edgecolor='none')\n",
    "\n",
    "# Escribe el número absoluto de outliers encima de cada barra\n",
    "# además del porcentaje que ya se ve en el eje Y\n",
    "for bar, n in zip(bars, numeros):\n",
    "    ax.text(bar.get_x() + bar.get_width() / 2,\n",
    "            bar.get_height() + 0.1,\n",
    "            f'n={n:,}',\n",
    "            ha='center', va='bottom', fontsize=10)\n",
    "\n",
    "ax.set_title('Porcentaje de outliers por variable (método IQR)',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Variable')\n",
    "ax.set_ylabel('% sobre el total de registros')\n",
    "\n",
    "# 1.25 deja un 25% de espacio extra arriba para los números\n",
    "ax.set_ylim(0, max(porcentajes) * 1.25)\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_outliers_resumen.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# --- PASO 2: Verificación de la naturaleza de los outliers ---\n",
    "# Antes de decidir qué ahcer con los outliers hay que entender qué aportan en mis datos\n",
    "# Si son errores hay que eliminarlos o corregirlos\n",
    "# Si son valores reales hay que conservarlos\n",
    "print('VERIFICACIÓN DE NATURALEZA DE OUTLIERS')\n",
    "print('=' * 60)\n",
    "\n",
    "for var in vars_outliers:\n",
    "    # Se recalculan los límites para cada variable\n",
    "    Q1  = base[var].quantile(0.25)\n",
    "    Q3  = base[var].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lim_sup = Q3 + 1.5 * IQR\n",
    "    lim_inf = Q1 - 1.5 * IQR\n",
    "    \n",
    "    # Filtra los outliers superiores — valores por encima del límite superior\n",
    "    out_sup = base[base[var] > lim_sup][var]\n",
    "    # Filtra los outliers inferiores — valores por debajo del límite inferior\n",
    "    out_inf = base[base[var] < lim_inf][var]\n",
    "\n",
    "    # Solo imprime si hay outliers en ese extremo\n",
    "    # Muestra el valor máximo y la media de los outliers para entender\n",
    "    # qué tan extremos son esos valores\n",
    "    if len(out_sup) > 0:\n",
    "        print(f'{var} — outliers superiores:')\n",
    "        print(f'  Max: {out_sup.max():,.2f} | Media outliers: {out_sup.mean():,.2f}')\n",
    "    if len(out_inf) > 0:\n",
    "        print(f'{var} — outliers inferiores:')\n",
