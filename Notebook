    "print(f\"Registros originales: {len(vle):,}\")\n",
    "print(f\"Variables originales: {list(vle.columns)}\")\n",
    "print(f\"\\nNulos originales:\")\n",
    "# Cuenta los nulos por columna\n",
    "print(vle.isnull().sum())\n",
    "\n",
    "# --- VERIFICACIÓN PREVIA: entender los nulos de week_from y week_to ---\n",
    "print(f\"\\n¿Qué tipos de actividad tienen nulos en week_from?\")\n",
    "# De las filas donde week_from es nulo, muestra qué tipos de actividad son\n",
    "print(vle[vle['week_from'].isnull()]['activity_type'].value_counts())\n",
    "\n",
    "print(f\"\\n¿Qué tipos de actividad SÍ tienen week_from?\")\n",
    "# Los tipos de actividad que sí tienen week_from, para comparar con los que no tienen\n",
    "print(vle[vle['week_from'].notnull()]['activity_type'].value_counts())\n",
    "\n",
    "# --- DECISIÓN 1: Eliminar columnas week_from y week_to ---\n",
    "# Justificación: El 82,39% de los valores son nulos en ambas columnas.\n",
    "# Al investigar se comprueba que los nulos son estructurales: la mayoría\n",
    "# de tipos de actividad no tienen semana asignada porque son recursos\n",
    "# de acceso libre en cualquier momento del curso. Con más de 4 de cada\n",
    "# 5 valores vacíos estas columnas no son recuperables mediante\n",
    "# imputación sin introducir información falsa. Se eliminan para\n",
    "# reducir ruido en el análisis.\n",
    "\n",
    "# Primero calculamos el porcentaje ANTES de eliminar\n",
    "pct_nulos_week = vle['week_from'].isnull().mean() * 100\n",
    "print(f\"\\n DECISIÓN 1 — week_from y week_to eliminadas:\")\n",
    "print(f\"   % nulos en week_from: {pct_nulos_week:.2f}%\")\n",
    "\n",
    "# Luego eliminamos\n",
    "vle = vle.drop(columns=['week_from', 'week_to'])\n",
    "print(f\"   Variables restantes: {list(vle.columns)}\")\n",
    "print(f\"   Nulos restantes: {vle.isnull().sum().sum()}\")\n",
    "\n",
    "# --- DECISIÓN 2: Verificar activity_type ---\n",
    "print(f\"\\n DECISIÓN 2 — Tipos de actividad en el VLE:\")\n",
    "# Lista los tipos de recursos que existen en la plataforma y cuántos hay de cada uno\n",
    "print(vle['activity_type'].value_counts())\n",
    "\n",
    "# --- DECISIÓN 3: Crear variable activity_group ---\n",
    "# Justificación: Agrupamos los 20 tipos de actividad en 4 categorías\n",
    "# más amplias para facilitar el análisis posterior.\n",
    "# Tras revisar la clasificación se detectó que externalquiz estaba\n",
    "# incorrectamente en Otros cuando debería estar en Evaluacion.\n",
    "# Del mismo modo, page y htmlactivity se clasificaron como Contenido\n",
    "# por ser páginas de material del curso.\n",
    "\n",
    "def clasificar_actividad(tipo):\n",
    "    if tipo in ['resource', 'oucontent', 'url', 'subpage', 'homepage',\n",
    "                'glossary', 'sharedsubpage', 'htmlactivity', 'page']:\n",
    "        return 'Contenido'\n",
    "    elif tipo in ['quiz', 'questionnaire', 'externalquiz']:\n",
    "        return 'Evaluacion'\n",
    "    elif tipo in ['forumng', 'oucollaborate', 'ouelluminate']:\n",
    "        return 'Colaboracion'\n",
    "    else:\n",
    "        return 'Otros'\n",
    "\n",
    "# Aplicar la función clasificar_actividad a cada fila de la columna activity_type\n",
    "# Guarda el resultado en una columna nueva llamada activity_group\n",
    "vle['activity_group'] = vle['activity_type'].apply(clasificar_actividad)\n",
    "\n",
    "print(f\"\\n DECISIÓN 3 — Nueva variable 'activity_group':\")\n",
    "# Cuenta cuántos recursos hay en cada categoría\n",
    "print(vle['activity_group'].value_counts())\n",
    "\n",
    "# Verificación de la clasificación\n",
    "print(f\"\\n   Clasificación detallada:\")\n",
    "# .drop_duplicates() --> Elimina filas repetidas para ver el tipo de actividad una vez\n",
    "# .sort_values('activity_group') --> Ordena por categoría para ver juntos todos los tipos de cada grupo\n",
    "print(vle[['activity_type', 'activity_group']].drop_duplicates().sort_values('activity_group'))\n",
    "\n",
    "# --- RESUMEN FINAL ---\n",
    "print(f\"\\n RESUMEN LIMPIEZA VLE:\")\n",
    "print(f\"   Registros antes: {len(vle_original):,}\")\n",
    "print(f\"   Registros después: {len(vle):,}\")\n",
    "# Confirmar que no quedan nulos\n",
    "print(f\"   Nulos restantes: {vle.isnull().sum().sum()}\")\n",
    "# Ver las variables antes\n",
    "print(f\"   Variables originales: {len(vle_original.columns)}\")\n",
    "print(f\"   Variables después: {len(vle.columns)}\")\n",
    "# Lista las variables finales para confirmar que están exactamente las correctas\n",
    "print(f\"   Variables finales: {list(vle.columns)}\")\n",
    "print(f\"\\n Limpieza de vle completada\")"
