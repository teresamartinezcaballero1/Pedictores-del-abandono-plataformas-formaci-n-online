    "# ============================================================\n",
    "# CELDA 9: VARIABLES DERIVADAS DEL STUDENTVLE\n",
    "# ============================================================\n",
    "\n",
    "print(\"CREACIÓN DE VARIABLES DERIVADAS DEL VLE\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "print(f\"Registros studentVle originales: {len(studentVle):,}\")\n",
    "#Lista las variables de studentVle\n",
    "print(f\"Variables originales: {list(studentVle.columns)}\")\n",
    "\n",
    "# --- PASO PREVIO: Cruzar studentVle con vle para añadir activity_group ---\n",
    "# Justificación: Necesitamos saber el tipo de actividad de cada interacción \n",
    "#para poder calcular variables de comportamiento diferenciadas por tipo de recurso.\n",
    "#how: left--> conserva TODAS las filas aunque no tengan correspondencia\n",
    "studentVle_enriquecido = studentVle.merge(\n",
    "    vle[['id_site', 'activity_group']],\n",
    "    on='id_site',\n",
    "    how='left'\n",
    ")\n",
    "print(f\"\\n studentVle cruzado con vle:\")\n",
    "print(f\"   Registros: {len(studentVle_enriquecido):,}\")\n",
    "print(f\"   Variables: {list(studentVle_enriquecido.columns)}\")\n",
    "\n",
    "# =============================================================\n",
    "# CÁLCULO DE VARIABLES DERIVADAS POR ESTUDIANTE\n",
    "# =============================================================\n",
    "\n",
    "print(\"\\nCalculando variables derivadas por estudiante...\")\n",
    "\n",
    "# --- VARIABLE 1: total_clicks ---\n",
    "# Justificación: Total de clics de cada estudiante en toda la plataforma. \n",
    "#Indicador general de actividad e implicación.\n",
    "#Groupby--> agrupa los registros por estuidante y módulo, es decir, todas las filas que pertenecen al mismo estudiante en el mismo módulo\n",
    "#['sum_click'].sum--> suma los clics de cada grupo\n",
    "#.reset_index()--> convierte el resultado en una tabla normal con columnas \n",
    "total_clicks = studentVle.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['sum_click'].sum().reset_index()\n",
    "#Cambiamos el nombre de la columna de sum_click a total_clicks\n",
    "total_clicks.columns = ['id_student', 'code_module', 'code_presentation', 'total_clicks']\n",
    "print(f\"\\n VARIABLE 1 — total_clicks:\")\n",
    "print(f\"   Media: {total_clicks['total_clicks'].mean():.0f} clics por estudiante\")\n",
    "#Estudiante menos activo\n",
    "print(f\"   Mínimo: {total_clicks['total_clicks'].min():,}\")\n",
    "#Estudiante más activo\n",
    "print(f\"   Máximo: {total_clicks['total_clicks'].max():,}\")\n",
    "\n",
    "# --- VARIABLE 2: active_days ---\n",
    "# Justificación: Número de días distintos en los que el estudiante accedió a la plataforma. \n",
    "#Indicador de constancia y regularidad.\n",
    "#Igual que con total_clicks pero --> .nunique()--> cuenta los valores únicos de date\n",
    "active_days = studentVle.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['date'].nunique().reset_index()\n",
    "active_days.columns = ['id_student', 'code_module', 'code_presentation', 'active_days']\n",
    "print(f\"\\n VARIABLE 2 — active_days:\")\n",
    "#Media de días activos de todos los estudiantes--> .0f es para que sean números enteros\n",
    "print(f\"   Media: {active_days['active_days'].mean():.0f} días activos por estudiante\")\n",
    "#Estudiante que menos días accedió a la plataforma \n",
    "print(f\"   Mínimo: {active_days['active_days'].min()}\")\n",
    "#Estudiante que más días accedió a la plataforma\n",
    "print(f\"   Máximo: {active_days['active_days'].max()}\")\n",
    "\n",
    "# --- VARIABLE 3: avg_clicks_per_day ---\n",
    "# Justificación: Intensidad media de uso diario de la plataforma.\n",
    "# Un estudiante puede tener pocos días activos pero muy intensos, o muchos días con poca actividad.\n",
    "#Hace el merge con total_clicks y active_days\n",
    "vle_por_estudiante = total_clicks.merge(active_days, \n",
    "    on=['id_student', 'code_module', 'code_presentation'])\n",
    "#Divide el total de clics entre los días activos\n",
    "vle_por_estudiante['avg_clicks_per_day'] = (\n",
    "    vle_por_estudiante['total_clicks'] / vle_por_estudiante['active_days']\n",
    ").round(2)\n",
    "print(f\"\\n VARIABLE 3 — avg_clicks_per_day:\")\n",
    "#La media de clics por día de todos los estudiantes. \n",
    "print(f\"   Media: {vle_por_estudiante['avg_clicks_per_day'].mean():.2f} clics/día\")\n",
    "#El estudiante con menos clics por día activo\n",
    "print(f\"   Mínimo: {vle_por_estudiante['avg_clicks_per_day'].min():.2f}\")\n",
    "#El estudiante con más clics por día activo\n",
    "print(f\"   Máximo: {vle_por_estudiante['avg_clicks_per_day'].max():.2f}\")\n",
    "\n",
    "# --- VARIABLE 4: first_activity_day ---\n",
    "# Justificación: Día en el que el estudiante accedió por primera\n",
    "# vez a la plataforma. Los valores negativos indican que accedió\n",
    "# antes del inicio oficial del curso.\n",
    "#.min--> busca el valor más pequeño de date por estudiante--> el primer día que accedió\n",
    "first_activity = studentVle.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['date'].min().reset_index()\n",
    "first_activity.columns = ['id_student', 'code_module', 'code_presentation', 'first_activity_day']\n",
    "print(f\"\\n VARIABLE 4 — first_activity_day:\") \n",
    "# Día medio en que los estudiantes acceden por primera vez\n",
    "print(f\"   Media: {first_activity['first_activity_day'].mean():.0f} días desde inicio\")\n",
    "# El estudiante que accedió más pronto (valor más negativo = antes del inicio)\n",
    "print(f\"   Mínimo: {first_activity['first_activity_day'].min()} días\")\n",
    "# El estudiante que accedió más tarde por primera vez\n",
    "print(f\"   Máximo: {first_activity['first_activity_day'].max()} días\")\n",
    "\n",
    "# --- VARIABLE 5: last_activity_day ---\n",
    "# Justificación: Último día en el que el estudiante accedió a la plataforma. \n",
    "#Indicador clave de abandono: si el último acceso es muy temprano en el curso, es señal de desconexión.\n",
    "#Se usa .max--> para ver el último día\n",
    "last_activity = studentVle.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['date'].max().reset_index()\n",
    "last_activity.columns = ['id_student', 'code_module', 'code_presentation', 'last_activity_day']\n",
    "print(f\"\\n VARIABLE 5 — last_activity_day:\")\n",
    "#El día medio en que los estudiantes hacen su último acceso.\n",
    "print(f\"   Media: {last_activity['last_activity_day'].mean():.0f} días desde inicio\")\n",
    "#El estudiante que desapareció antes. \n",
    "print(f\"   Mínimo: {last_activity['last_activity_day'].min()} días\")\n",
    "#El estudiante que estuvo activo más tiempo. \n",
    "print(f\"   Máximo: {last_activity['last_activity_day'].max()} días\")\n",
    "\n",
    "# --- VARIABLE 6: clicks_contenido, clicks_evaluacion, clicks_colaboracion ---\n",
    "# Justificación: Desglose de clics por tipo de actividad.\n",
    "# Permite analizar si el perfil de uso de la plataforma influye en el resultado académico.\n",
    "#.unstack(fill_value=0) convierte las categorías de activity_group en columnas separadas\n",
    "#El fill_value=0 rellena con 0 los tipos de actividad que el estudiante no usó\n",
    "clicks_por_grupo = studentVle_enriquecido.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation', 'activity_group']\n",
    ")['sum_click'].sum().unstack(fill_value=0).reset_index()\n",
    "\n",
    "#Renombra cada columna añadiendo el prefijo clicks_ y convirtiendo a minúsculas:\n",
    "#El if col not in clicks_por_grupo.columns comprueba que la columna existe antes de renombrarla, por si algún tipo de actividad no aparece en los datos.\n",
    "clicks_por_grupo.columns.name = None\n",
    "for col in ['Contenido', 'Colaboracion', 'Evaluacion', 'Otros']:\n",
    "    if col not in clicks_por_grupo.columns:\n",
    "        clicks_por_grupo[col] = 0\n",
    "    clicks_por_grupo = clicks_por_grupo.rename(\n",
    "        columns={col: f'clicks_{col.lower()}'}\n",
    "    )\n",
    "\n",
    "print(f\"\\n VARIABLE 6 — clicks por tipo de actividad:\")\n",
    "for col in ['clicks_contenido', 'clicks_colaboracion', 'clicks_evaluacion', 'clicks_otros']:\n",
    "    if col in clicks_por_grupo.columns:\n",
    "        print(f\"   {col}: media {clicks_por_grupo[col].mean():.0f}\")\n",
    "\n",
    "# --- INTEGRACIÓN DE TODAS LAS VARIABLES VLE ---\n",
    "print(\"\\nIntegrando todas las variables VLE...\")\n",
