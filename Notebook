    "print(abandono_genero)\n",
    "\n",
    "# Tasa de abandono por age_band (edad)\n",
    "# Mismo patrón que por género pero agrupando por franja de edad\n",
    "print(\"\\n Tasa de abandono por edad:\")\n",
    "abandono_edad = base.groupby('age_band')['target_withdrawal'].agg(['mean', 'sum', 'count'])\n",
    "abandono_edad.columns = ['tasa_abandono', 'num_abandonos', 'total']\n",
    "abandono_edad['tasa_abandono'] = (abandono_edad['tasa_abandono']*100).round(1)\n",
    "print(abandono_edad)\n",
