    "# ============================================================\n",
    "# CELDA 14: ANÁLISIS EXPLORATORIO COMPLETO\n",
    "# ============================================================\n",
    "\n",
    "print(\"ANÁLISIS EXPLORATORIO COMPLETO\")\n",
    "print(\"=\" * 50)\n",
