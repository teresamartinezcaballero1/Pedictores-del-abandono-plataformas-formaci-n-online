    "# ============================================================\n",
    "# CELDA 20 — Modelo B: Random Forest\n",
    "# ============================================================\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.metrics import (confusion_matrix, classification_report,\n",
    "                             roc_auc_score, roc_curve,\n",
    "                             accuracy_score, f1_score)\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "# --- PASO 1: Entrenar Random Forest ---\n",
    "# Random Forest construye múltiples árboles de decisión distintos y combina sus predicciones por votación mayoritaria.\n",
    "# Cada árbol se entrena con una muestra aleatoria de datos y variables,lo que hace que cada árbol sea distinto y sus errores no se acumulen.\n",
    "\n",
    "# n_estimators=200--> construye 200 árboles distintos\n",
    "# Más árboles = predicciones más estables y menos sensibles a datos atípicos. \n",
    "# A partir de 200 la mejora es marginal pero el coste computacional sigue subiendo.\n",
    "\n",
    "# class_weight='balanced'--> compensa el desbalance 68,5%/31,5%\n",
    "# Sin esto el modelo aprendería que decir siempre \"no abandona\" es la estrategia más segura porque acierta el 68,5% de las veces.\n",
    "# Con 'balanced' el modelo presta más atención a los abandonos aunque sean la clase minoritaria.\n",
    "\n",
    "# random_state=42 --> reproducibilidad\n",
    "# n_jobs=-1--> usa todos los núcleos del procesador en paralelo\n",
    "# reduciendo significativamente el tiempo de entrenamiento con 200 árboles y 25.185 estudiantes\n",
    "rf = RandomForestClassifier(\n",
    "    n_estimators=200,\n",
    "    class_weight='balanced',\n",
    "    random_state=42,\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "# Random Forest NO necesita datos escalados a diferencia de la Regresión Logística \n",
    "# se entrena directamente con X_train_m porque los árboles trabajan con umbrales de división,\n",
    "# no con distancias matemáticas entre variables\n",
    "rf.fit(X_train_m, y_train_m)\n",
    "\n",
    "print('RANDOM FOREST — ENTRENAMIENTO')\n",
    "print('=' * 50)\n",
    "print(f'Árboles construidos: {rf.n_estimators}')\n",
    "print(f'Variables utilizadas: {X_train_m.shape[1]}')\n",
    "print(f'Estudiantes de entrenamiento: {X_train_m.shape[0]:,}')\n",
    "\n",
    "# --- PASO 2: Predicciones ---\n",
    "# Random Forest NO usa datos escalados — se le pasa X_test_m directamente\n",
    "# a diferencia de la Regresión Logística que usaba X_test_m_scaled\n",
    "\n",
    "# predict --> clase predicha: 0 (no abandona) o 1 (abandona)\n",
    "y_pred_rf = rf.predict(X_test_m)\n",
    "\n",
    "# predict_proba --> probabilidad de abandono para cada estudiante\n",
    "# [:, 1] coge solo la probabilidad de la clase 1 (abandona)\n",
    "y_prob_rf = rf.predict_proba(X_test_m)[:, 1]\n",
    "\n",
    "# --- PASO 3: Métricas ---\n",
    "# Mismas métricas que en la Regresión Logística para poder comparar los dos modelos de forma justa en la celda 21\n",
    "acc_rf = accuracy_score(y_test_m, y_pred_rf)\n",
    "f1_rf  = f1_score(y_test_m, y_pred_rf)\n",
    "auc_rf = roc_auc_score(y_test_m, y_prob_rf)\n",
    "\n",
    "print(f'\\nMÉTRICAS — RANDOM FOREST')\n",
    "print('=' * 50)\n",
    "print(f'  Accuracy:  {acc_rf*100:.2f}%')\n",
    "print(f'  F1-Score:  {f1_rf:.4f}')\n",
    "print(f'  AUC-ROC:   {auc_rf:.4f}')\n",
    "print(f'\\nReporte completo:')\n",
    "\n",
    "# classification_report desglosa precision, recall y F1 por clase\n",
    "# Permite ver si el modelo funciona bien tanto para abandonos como para no abandonos — no solo en global\n",
    "print(classification_report(y_test_m, y_pred_rf,\n",
    "      target_names=['No abandona', 'Abandona']))\n",
    "\n",
    "# --- GRÁFICO 1: Matriz de confusión — Random Forest ---\n",
    "# Misma estructura que la matriz de la Regresión Logística para poder comparar visualmente los errores de ambos modelos\n",
    "\n",
    "# Los resultados que salieron:\n",
    "\n",
    "#                    Pred: No abandona  |  Pred: Abandona\n",
    "# Real: No abandona        3.844        |       469\n",
    "# Real: Abandona             417        |      1.567\n",
    "\n",
    "# Comparando con Regresión Logística:\n",
    "# Falsos Positivos: 544--> 469 (-75 alarmas falsas innecesarias)\n",
    "# Falsos Negativos: 435--> 417 (-18 abandonos no detectados)\n",
    "# Random Forest comete menos errores en ambas direcciones\n",
    "cm_rf = confusion_matrix(y_test_m, y_pred_rf)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "sns.heatmap(cm_rf, annot=True, fmt='d', cmap='Blues',\n",
    "            xticklabels=['Pred: No abandona', 'Pred: Abandona'],\n",
    "            yticklabels=['Real: No abandona', 'Real: Abandona'],\n",
    "            ax=ax)\n",
    "ax.set_title('Matriz de confusión — Random Forest',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_ylabel('Valor real')\n",
    "ax.set_xlabel('Predicción del modelo')\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_confusion_rf.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# --- GRÁFICO 2: Curva ROC ---\n",
    "# Este gráfico superpone las curvas ROC de ambos modelos para comparar visualmente su capacidad discriminatoria.\n",
    "# Permite ver de un vistazo cuál de los dos modelos es mejor.\n",
    "\n",
    "# Se calculan los puntos de la curva ROC del Random Forest\n",
    "fpr_rf, tpr_rf, _ = roc_curve(y_test_m, y_prob_rf)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "\n",
    "# Curva Random Forest — línea continua porque es el modelo principal\n",
    "ax.plot(fpr_rf, tpr_rf, color='tomato', linewidth=2.5,\n",
    "        label=f'Random Forest (AUC = {auc_rf:.3f})')\n",
    "\n",
    "# Curva Regresión Logística — línea discontinua para distinguirla\n",
    "# fpr_rl y tpr_rl vienen calculados de la celda 19\n",
    "ax.plot(fpr_rl, tpr_rl, color='steelblue', linewidth=2,\n",
    "        linestyle='--',\n",
    "        label=f'Regresión Logística (AUC = {auc_rl:.3f})')\n",
    "\n",
    "# Línea diagonal--> modelo aleatorio que adivina al azar (AUC=0.5)\n",
    "# Ambos modelos deben estar muy por encima de esta línea\n",
    "ax.plot([0,1],[0,1], color='gray', linestyle=':',\n",
    "        linewidth=1.5, label='Modelo aleatorio (AUC = 0.500)')\n",
    "\n",
    "# Relleno bajo la curva del Random Forest para resaltar\n",
    "# que es el modelo seleccionado\n",
    "ax.fill_between(fpr_rf, tpr_rf, alpha=0.1, color='tomato')\n",
    "\n",
    "ax.set_title('Curva ROC — Comparación de modelos',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Tasa de Falsos Positivos')\n",
    "ax.set_ylabel('Tasa de Verdaderos Positivos')\n",
    "ax.legend(loc='lower right')\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_roc_comparacion.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# --- GRÁFICO 3: Feature Importance ---\n",
    "# Feature Importance es una de las grandes ventajas de Random Forest sobre la Regresión Logística \n",
    "# mide cuánto contribuye cada variable a reducir el error de predicción en los 200 árboles.\n",
    "# A diferencia de los coeficientes de la Regresión Logística, Feature Importance captura relaciones no lineales entre variables.\n",
    "\n",
    "# rf.feature_importances_ --> array con la importancia de cada variable\n",
    "# Los valores suman 1.0 — representan la importancia relativa\n",
    "# Una variable con importancia 0.264 explica el 26,4% de las decisiones\n",
    "importancia = pd.DataFrame({\n",
    "    'Variable': vars_modelo_final,\n",
    "    'Importancia': rf.feature_importances_\n",
    "}).sort_values('Importancia', ascending=False).head(15)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 7))\n",
    "# Gráfico horizontal para que los nombres de variables se lean bien\n",
    "bars = ax.barh(importancia['Variable'],\n",
