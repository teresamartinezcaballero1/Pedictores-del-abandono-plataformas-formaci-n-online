    "print(base[vars_numericas].describe().round(2))\n",
    "\n",
    "# Variables categóricas — contienen texto en lugar de números\n",
    "# Se analizan por separado porque describe() no funciona bien con texto\n",
    "vars_categoricas = ['gender', 'region', 'highest_education',\n",
    "                    'age_band', 'imd_band', 'final_result',\n",
    "                    'completion_status']\n",
    "\n",
    "print(\"\\n Distribución de variables categóricas:\")\n",
    "for col in vars_categoricas:\n",
    "    print(f\"\\n{col}:\")\n",
    "    conteo = base[col].value_counts()\n",
    "    for val, n in conteo.items():\n",
    "        print(f\"   {val}: {n:,} ({n/len(base)*100:.1f}%)\")\n",
    "\n",
    "# Variables categóricas\n",
    "vars_categoricas = ['gender', 'region', 'highest_education',\n",
    "                    'age_band', 'imd_band', 'final_result',\n",
    "                    'completion_status']\n",
    "\n",
    "print(\"\\n Distribución de variables categóricas:\")\n",
    "for col in vars_categoricas:\n",
    "    print(f\"\\n{col}:\")\n",
    "    conteo = base[col].value_counts()\n",
    "    for val, n in conteo.items():\n",
    "        print(f\"   {val}: {n:,} ({n/len(base)*100:.1f}%)\")\n",
    "\n",
    "# --- Análisis de desbalance de clases ---\n",
    "print(\"\\n DESBALANCE DE CLASES EN LA BASE FINAL:\")\n",
    "\n",
    "# target_withdrawal es la variable que los modelos tienen que predecir\n",
    "# Vale 1 si el estudiante abandonó (Withdrawn) y 0 si no abandonó\n",
    "# Es importante analizar cuántos hay de cada clase antes de modelizar\n",
    "# porque si hay muchos más de una clase que de otra el modelo puede\n",
    "# aprender a decir siempre la clase mayoritaria y parecer bueno sin serlo\n",
    "\n",
    "# value_counts() cuenta cuántos estudiantes hay en cada clase\n",
    "# 0 = no abandona | 1 = abandona\n",
    "abandono = base['target_withdrawal'].value_counts()\n",
    "\n",
    "# normalize=True calcula el porcentaje en lugar del número absoluto\n",
    "# * 100 convierte la proporción (0.685) a porcentaje (68.5)\n",
    "abandono_pct = base['target_withdrawal'].value_counts(normalize=True) * 100\n",
    "\n",
    "# Muestra una tabla con la frecuencia y el porcentaje de cada clase\n",
    "print(pd.DataFrame({'Frecuencia': abandono, 'Porcentaje': abandono_pct.round(1)}))\n",
    "\n",
    "# El ratio mide cuántas veces hay más estudiantes de una clase que de otra\n",
    "# Por ejemplo ratio=2.2 significa que hay 2.2 veces más no abandonos que abandonos\n",
    "# iloc[0] coge el valor más frecuente (no abandona)\n",
    "# iloc[1] coge el valor menos frecuente (abandona)\n",
    "ratio = abandono.iloc[0] / abandono.iloc[1]\n",
    "print(f\"\\n  Ratio de desbalance: {ratio:.1f}:1\")\n",
    "\n",
    "# CONCLUSIÓN:\n",
    "# Con este desbalance un modelo que dijera siempre \"no abandona\"\n",
    "# tendría una Accuracy del 68.5% pero no detectaría ningún abandono real\n",
    "# Por eso usamos F1-Score y AUC-ROC como métricas principales:\n",
    "# - F1-Score penaliza tanto los abandonos no detectados como las falsas alarmas\n",
    "# - AUC-ROC mide si el modelo realmente distingue entre los dos grupos\n",
    "# Ambas métricas son mucho más honestas que Accuracy con datasets desbalanceados\n",
    "print(\"   → Justifica el uso de F1-Score y AUC-ROC como métricas principales\")\n",
    "print(\"   → Accuracy se calculará pero no será la métrica de referencia\")\n",
    "\n",
    "# =============================================================\n",
    "# PARTE 2: ANÁLISIS DE CORRELACIONES\n",
    "# =============================================================\n",
    "\n",
    "print(\"\\n--- ANÁLISIS DE CORRELACIONES ---\")\n",
    "\n",
    "# Se incluyen las más relevantes para predecir el abandono\n",
    "# Se excluyen id_student y variables centinela\n",
    "vars_correlacion = ['target_withdrawal', 'total_clicks', 'active_days',\n",
    "                    'avg_score', 'num_assessments_submitted', 'submitted_exam',\n",
    "                    'avg_submission_delay', 'disability_flag',\n",
    "                    'num_of_prev_attempts', 'studied_credits']\n",
    "\n",
    "# .corr() calcula la matriz de correlaciones de Pearson entre todas las variables\n",
    "# ['target_withdrawal'] selecciona solo la columna de correlaciones con el abandono\n",
    "# .sort_values() ordena de menor a mayor para ver las más negativas primero\n",
    "correlaciones = base[vars_correlacion].corr()['target_withdrawal'].sort_values()\n",
    "\n",
    "print(\"\\n Correlación con target_withdrawal (abandono):\")\n",
    "print(correlaciones.round(3))\n",
    "\n",
    "# Gráfico de correlaciones\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "# Se elimina target_withdrawal de sí misma porque su correlación consigo misma es 1\n",
    "# y distorsionaría la escala del gráfico\n",
    "correlaciones_plot = correlaciones.drop('target_withdrawal')\n",
    "# Rojo para correlaciones positivas (aumentan el abandono)\n",
    "# Verde para correlaciones negativas (reducen el abandono)\n",
    "colores_corr = ['tomato' if x > 0 else 'mediumseagreen' \n",
    "                for x in correlaciones_plot.values]\n",
    "bars = ax.barh(correlaciones_plot.index, correlaciones_plot.values,\n",
    "               color=colores_corr, edgecolor='none')\n",
    "ax.set_title('Correlación de variables con el abandono (target_withdrawal)',\n",
    "             fontweight='bold', fontsize=14)\n",
    "ax.set_xlabel('Coeficiente de correlación', fontsize=12)\n",
    "# Línea vertical en 0 para separar correlaciones positivas y negativas\n",
    "ax.axvline(x=0, color='black', linewidth=0.8)\n",
    "# Escribe el valor exacto de cada correlación al lado de cada barra\n",
    "# Si es positiva lo pone a la derecha, si es negativa a la izquierda\n",
    "for bar, val in zip(bars, correlaciones_plot.values):\n",
    "    ax.text(val + 0.002 if val >= 0 else val - 0.002,\n",
    "            bar.get_y() + bar.get_height()/2.,\n",
    "            f'{val:.3f}', va='center',\n",
    "            ha='left' if val >= 0 else 'right', fontsize=10)\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_correlaciones.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\" Gráfico correlaciones guardado\")\n",
    "\n",
    "# =============================================================\n",
    "# PARTE 3: ANÁLISIS POR GRUPOS\n",
    "# =============================================================\n",
    "\n",
    "print(\"\\n--- ANÁLISIS POR GRUPOS ---\")\n",
    "\n",
    "# Tasa de abandono por género\n",
    "# --- Tasa de abandono por género ---\n",
    "# .agg(['mean', 'sum', 'count']) calcula tres estadísticos a la vez:\n",
    "# sum → número absoluto de abandonos\n",
    "# count → total de estudiantes en ese grupo\n",
    "print(\"\\n Tasa de abandono por género:\")\n",
    "abandono_genero = base.groupby('gender')['target_withdrawal'].agg(['mean', 'sum', 'count'])\n",
    "abandono_genero.columns = ['tasa_abandono', 'num_abandonos', 'total']\n",
    "# Multiplicar por 100 para convertir proporción a porcentaje\n",
