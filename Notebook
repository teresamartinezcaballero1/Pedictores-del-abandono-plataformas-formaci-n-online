    "# ============================================================\n",
    "# CELDA 8: LIMPIEZA DE VLE\n",
    "# ============================================================\n",
    "print(\"LIMPIEZA DE VLE\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Copia de seguridad de la tabla original\n",
    "vle_original = vle.copy()\n",
    "\n",
