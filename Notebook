    "# =============================================================\n",
    "\n",
    "print(\"\\n--- ESTADÍSTICOS DESCRIPTIVOS ---\")\n",
    "\n",
    "# Variables numéricas seleccionadas para el análisis\n",
    "# Se excluyen id_student y variables centinela como still_registered\n",
    "vars_numericas = ['total_clicks', 'active_days', 'avg_clicks_per_day',\n",
    "                  'avg_score', 'num_assessments_submitted', 'submitted_exam',\n",
