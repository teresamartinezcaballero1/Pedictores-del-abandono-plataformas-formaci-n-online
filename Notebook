    "# ============================================================\n",
    "# CELDA 5: LIMPIEZA DE STUDENTINFO\n",
    "# ============================================================\n",
    "\n",
    "print(\"LIMPIEZA DE STUDENTINFO\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "#Se hace una copia de la tabla original por si durante la limpieza es necesario volver al estado inicial\n",
    "studentInfo_original = studentInfo.copy()\n",
    "print(f\"Registros originales: {len(studentInfo):,}\")\n",
