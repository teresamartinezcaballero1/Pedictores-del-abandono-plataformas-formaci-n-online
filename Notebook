    "# ============================================================\n",
    "# CELDA 17 — Preparación del entorno para el análisis del dato\n",
    "# ============================================================\n",
    "# Carga de librerías para el análisis predictivo\n",
    "# Se importan todas las herramientas necesarias antes de empezar\n",
    "\n",
    "# preprocessing--> herramientas para transformar los datos antes del modelo\n",
    "# LabelEncoder--> convierte texto a números\n",
    "# StandardScaler--> estandariza variables numéricas a media 0 y desviación 1\n",
    "from sklearn.preprocessing import LabelEncoder, StandardScaler\n",
    "# train_test_split--> divide los datos en entrenamiento y prueba\n",
    "from sklearn.model_selection import train_test_split\n",
    "# LogisticRegression--> modelo supervisado lineal (Modelo A)\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "# RandomForestClassifier--> modelo supervisado basado en árboles (Modelo B)\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "# KMeans--> modelo no supervisado de clustering (segmentación de perfiles)\n",
    "from sklearn.cluster import KMeans\n",
    "# Métricas para evaluar la calidad de los modelos\n",
    "# classification_report--> tabla completa de precision, recall y F1 por clase\n",
    "# confusion_matrix--> matriz que muestra aciertos y errores del modelo\n",
    "# roc_auc_score --> área bajo la curva ROC (capacidad discriminatoria)\n",
    "# roc_curve--> puntos para dibujar la curva ROC\n",
    "# f1_score--> métrica principal para datasets desbalanceados\n",
    "# accuracy_score--> porcentaje de predicciones correctas\n",
    "from sklearn.metrics import (classification_report, confusion_matrix,\n",
    "                             roc_auc_score, roc_curve,\n",
    "                             f1_score, accuracy_score)\n",
    "# PCA → reducción de dimensionalidad para visualizar clusters en 2D\n",
    "from sklearn.decomposition import PCA\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import warnings\n",
    "# Silencia advertencias técnicas que no son errores reales\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# --- PASO 1: Variables categóricas — qué son y por qué convertirlas ---\n",
    "# Los modelos de ML solo trabajan con números\n",
    "# Las variables categóricas (texto) hay que convertirlas a numérico\n",
    "# LabelEncoder asigna un número entero a cada categoría de forma automática\n",
    "# Por ejemplo: 'F' → 0, 'M' → 1\n",
    "vars_categoricas = ['gender', 'region', 'age_band',\n",
    "                    'highest_education', 'imd_band']\n",
    "# Diccionario donde se guardan los encoders de cada variable\n",
    "# para poder invertir la conversión después si se necesita\n",
    "encoders = {}\n",
    "# Se trabaja sobre una copia para no modificar la base original\n",
    "base_modelo = base.copy()\n",
    "\n",
    "print('ENCODING DE VARIABLES CATEGÓRICAS')\n",
    "print('=' * 50)\n",
    "\n",
    "for col in vars_categoricas:\n",
    "    le = LabelEncoder()\n",
    "    # fit_transform hace dos cosas a la vez:\n",
    "    # fit--> aprende qué categorías existen en esa columna\n",
    "    # transform--> convierte cada valor a su número correspondiente\n",
    "    # Se guarda el resultado en una columna nueva con sufijo _enc para mantener la columna original intacta\n",
    "    base_modelo[col + '_enc'] = le.fit_transform(\n",
    "        base_modelo[col].astype(str)\n",
    "    )\n",
    "    # Se guarda el encoder de esta variable para uso posterior\n",
    "    encoders[col] = le\n",
    "    # Se imprime el mapeo completo para documentar la conversión\n",
    "    mapping = dict(zip(le.classes_,\n",
    "                       le.transform(le.classes_)))\n",
    "    print(f'\\n{col}:')\n",
    "    for categoria, numero in mapping.items():\n",
    "        print(f'  {categoria} → {numero}')\n",
    "\n",
    "# --- PASO 2: Selección de variables para los modelos ---\n",
    "# Se excluyen tres variables por DATA LEAKAGE:\n",
    "# El data leakage ocurre cuando incluyes en el modelo información que en la realidad no estaría disponible en el momento de predecir.\n",
    "# Un sistema de alerta temprana se ejecuta DURANTE el curso,antes de que el abandono ocurra. Por tanto no puede usar\n",
    "# variables que solo existen DESPUÉS de que ocurra.\n",
    "\n",
    "# still_registered--> solo se sabe si siguió matriculado al FINAL del curso\n",
    "# days_to_unregistration--> solo existe si ya se dio de baja\n",
    "# activity_span--> usa last_activity_day, que solo se conoce cuando el estudiante deja de conectarse definitivamente\n",
    "\n",
    "# Variables numéricas que SÍ están disponibles durante el curso:\n",
    "vars_numericas = [\n",
    "    # Comportamiento digital — disponible en cualquier momento del curso\n",
    "    'total_clicks',          # cuántas veces ha accedido a la plataforma\n",
    "    'active_days',           # cuántos días distintos ha entrado\n",
    "    'avg_clicks_per_day',    # con qué intensidad estudia cada día\n",
    "\n",
    "    # Rendimiento académico — disponible a medida que entrega evaluaciones\n",
    "    'avg_score',             # nota media hasta el momento\n",
    "    'avg_score_tma',         # nota media en trabajos del tutor\n",
    "    'avg_score_cma',         # nota media en tests automáticos\n",
    "    'num_assessments_submitted', # cuántas evaluaciones ha entregado\n",
    "    'submitted_exam',        # si se presentó al examen final\n",
    "    'avg_submission_delay',  # si entrega tarde sistemáticamente\n",
    "\n",
    "    # Perfil del estudiante — disponible desde el momento de la matrícula\n",
    "    'num_of_prev_attempts',  # cuántas veces ha intentado este módulo antes\n",
    "    'studied_credits',       # créditos que estudia simultáneamente\n",
    "    'disability_flag',       # si tiene discapacidad registrada\n",
    "    'date_registration'      # cuándo se matriculó respecto al inicio\n",
    "]\n",
    "\n",
    "\n",
    "# Variables categóricas ya convertidas a numérico en el paso anterior\n",
    "# Se usa la versión _enc (encoded) no el texto original\n",
    "vars_categoricas_enc = [col + '_enc' for col in vars_categoricas]\n",
    "\n",
    "# Lista completa de variables predictoras que entran en los modelos\n",
    "# Son 18 variables en total: 13 numéricas + 5 categóricas codificadas\n",
    "todas_las_vars = vars_numericas + vars_categoricas_enc\n",
    "\n",
    "# Variable objetivo — lo que el modelo tiene que predecir\n",
    "# 1 = el estudiante abandonó | 0 = el estudiante no abandonó\n",
    "target = 'target_withdrawal'\n",
    "\n",
    "# --- PASO 3: Construcción del dataset X e y ---\n",
    "# En machine learning se usa la convención X e y:\n",
    "# X --> matriz de variables predictoras (las \"pistas\" que da el modelo)\n",
    "# y --> vector de la variable objetivo (lo que el modelo tiene que predecir)\n",
    "\n",
    "# X contiene todas las variables seleccionadas en el paso 2\n",
    "# Tiene forma (31.482 filas × 18 columnas)\n",
    "# Cada fila es un estudiante, cada columna es una variable predictora\n",
    "X = base_modelo[todas_las_vars]\n",
    "\n",
    "# y contiene solo la variable objetivo target_withdrawal\n",
    "# Tiene forma (31.482 valores)\n",
    "# Cada valor es 0 (no abandona) o 1 (abandona)\n",
    "y = base_modelo[target]\n",
    "\n",
    "print(f'\\n\\nDATASET PARA MODELOS')\n",
    "print('=' * 50)\n",
    "\n",
    "# X.shape[1] → número de columnas (variables)\n",
    "# X.shape[0] → número de filas (estudiantes)\n",
    "print(f'Variables predictoras (X): {X.shape[1]} variables, '\n",
    "      f'{X.shape[0]:,} estudiantes')\n",
    "\n",
    "# Confirma el desbalance de clases que ya detectamos en la celda 14\n",
    "# (y==0).sum() → cuenta cuántos ceros hay en y\n",
    "# (y==0).mean()*100 → calcula el porcentaje de ceros\n",
    "print(f'\\nDistribución de la variable objetivo:')\n",
    "print(f'  No abandona (0): {(y==0).sum():,} '\n",
    "      f'({(y==0).mean()*100:.1f}%)')\n",
    "print(f'  Abandona    (1): {(y==1).sum():,} '\n",
    "      f'({(y==1).mean()*100:.1f}%)')\n",
    "\n",
    "# Con 68.5% vs 31.5% un modelo que dijera siempre \"no abandona\"\n",
    "# tendría Accuracy del 68.5% pero F1-Score de 0\n",
    "# Por eso F1-Score es la métrica principal\n",
    "print(f'\\n  → Dataset desbalanceado: '\n",
    "      f'hay más no-abandonos que abandonos')\n",
    "print(f'  → Por eso usaremos F1-Score como métrica principal')\n",
    "\n",
    "# --- PASO 4: División train (80%) y test (20%) ---\n",
    "# train_test_split divide aleatoriamente los datos en dos grupos:\n",
    "# - Train (entrenamiento): el modelo aprende con estos datos\n",
    "# - Test (prueba): el modelo se evalúa con datos que NUNCA ha visto\n",
    "# Sin esta división el modelo parecería perfecto porque habría memorizado los datos de entrenamiento sin aprender nada real\n",
    "\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y,\n",
    "    # test_size=0.2 → el 20% va a test, el 80% a train\n",
    "    # Con 31.482 estudiantes: 25.185 train y 6.297 test\n",
    "    test_size=0.2,\n",
    "    # random_state=42--> fija la semilla aleatoria para que la división\n",
    "    # sea siempre la misma aunque ejecutes el código varias veces\n",
    "    # Sin esto cada ejecución daría resultados ligeramente distintos\n",
    "    # lo que dificultaría comparar modelos de forma justa\n",
    "    random_state=42,\n",
    "    # stratify=y--> garantiza que la proporción de abandonos sea la misma en train y en test (31.5% en ambos)\n",
    "    # Sin stratify podría ocurrir por azar que el test tuviera muchos más o muchos menos abandonos que el train,\n",
    "    # lo que haría la evaluación injusta e inconsistente\n",
    "    # Con datasets desbalanceados stratify es imprescindible\n",
    "    stratify=y\n",
    ")\n",
    "\n",
    "print(f'\\nDIVISIÓN TRAIN / TEST')\n",
    "print('=' * 50)\n",
    "print(f'  Train: {X_train.shape[0]:,} estudiantes '\n",
    "      f'({X_train.shape[0]/len(X)*100:.0f}%)')\n",
    "print(f'  Test:  {X_test.shape[0]:,} estudiantes '\n",
    "      f'({X_test.shape[0]/len(X)*100:.0f}%)')\n",
    "\n",
    "# Verifica que stratify funcionó correctamente:\n",
    "# ambos porcentajes deben ser exactamente 31.5%\n",
    "# Si fueran distintos la comparación entre modelos no sería válida\n",
    "print(f'\\n  % abandono en train: {y_train.mean()*100:.1f}%')\n",
    "print(f'  % abandono en test:  {y_test.mean()*100:.1f}%')\n",
    "print(f'  → Proporciones iguales gracias a stratify ')\n",
    "\n",
    "# --- PASO 5: Escalado para Regresión Logística ---\n",
    "# ¿Por qué necesita escalado la Regresión Logística?\n",
    "# Porque trabaja con distancias matemáticas entre variables.\n",
    "# Si total_clicks tiene valores hasta 24.139 y disability_flag\n",
    "# solo vale 0 o 1, el modelo pensaría que total_clicks es miles de veces más importante simplemente por tener\n",
    "# números más grandes — aunque no lo sea.\n",
    "# El escalado pone todas las variables en la misma escala: media 0 y desviación típica 1\n",
    "\n",
    "# Random Forest NO necesita escalado\n",
    "# ¿Por qué Random Forest NO necesita escalado?\n",
    "# Porque trabaja con umbrales de división, no con distancias.\n",
    "# Un árbol de decisión pregunta \"¿total_clicks > 500?\"\n",
    "# El valor del umbral no cambia si la variable está escalada o no.\n",
    "# Por eso Random Forest es indiferente a la escala de las variables.\n",
    "\n",
    "# Se crea el escalador — todavía no hace nada, solo se inicializa\n",
    "scaler = StandardScaler()\n",
    "\n",
    "# fit_transform sobre train hace dos cosas:\n",
    "# fit--> calcula la media y desviación típica de cada variable\n",
    "#       USANDO SOLO LOS DATOS DE TRAIN\n",
    "# transform--> aplica la estandarización a los datos de train\n",
    "# IMPORTANTE: ¿por qué fit solo con train y no con todos los datos?\n",
    "# Para evitar data leakage. Si calcularas la media con test incluido,\n",
    "# el modelo estaría usando información del futuro para escalar.\n",
    "# En producción real, cuando lleguen estudiantes nuevos,\n",
    "# no conocerás sus valores para calcular la media.\n",
    "# Por eso el escalador aprende la media y desviación solo del train\n",
    "# y luego aplica esos mismos valores al test.\n",
    "X_train_scaled = scaler.fit_transform(X_train)\n",
    "\n",
    "# transform (sin fit) sobre test aplica la misma estandarización\n",
    "# que aprendió con train — sin recalcular nada nuevo\n",
    "# Esto garantiza que train y test están en la misma escala\n",
    "# usando los mismos parámetros\n",
    "X_test_scaled  = scaler.transform(X_test)\n",
