    "# ============================================================\n",
    "# CELDA 21 — Comparación de modelos y selección del modelo final\n",
    "# ============================================================\n",
    "from sklearn.metrics import precision_score, recall_score\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "# --- PASO 1: Calcular métricas dinámicamente ---\n",
    "# Se calculan todas las métricas directamente desde los resultados reales de cada modelo \n",
    "# Esto garantiza que si se reentrena algún modelo con distintos parámetros, la comparación se actualiza automáticamente.\n",
    "\n",
    "# Precisión --> de los que el modelo predice como abandono, ¿qué porcentaje realmente abandonó?\n",
    "# Recall    --> de todos los que realmente abandonaron,¿qué porcentaje detectó el modelo?\n",
    "precision_rl = precision_score(y_test_m, y_pred_rl)\n",
    "recall_rl    = recall_score(y_test_m, y_pred_rl)\n",
    "\n",
    "# Se extraen los falsos positivos y falsos negativos directamente de la matriz de confusión\n",
    "# cm[0,1] -->fila 0 (no abandona real), columna 1 (predijo abandona)--> el modelo dijo que abandona pero no era verdad\n",
    "# cm[1,0] -->fila 1 (abandona real), columna 0 (predijo no abandona)--> el modelo dijo que no abandona pero sí lo hizo\n",
    "cm_rl_vals   = confusion_matrix(y_test_m, y_pred_rl)\n",
    "fp_rl        = cm_rl_vals[0, 1]  # falsas alarmas\n",
    "fn_rl        = cm_rl_vals[1, 0]  # abandonos no detectados\n",
    "\n",
    "# Mismas métricas para Random Forest\n",
    "precision_rf = precision_score(y_test_m, y_pred_rf)\n",
    "recall_rf    = recall_score(y_test_m, y_pred_rf)\n",
    "cm_rf_vals   = confusion_matrix(y_test_m, y_pred_rf)\n",
    "fp_rf        = cm_rf_vals[0, 1]\n",
    "fn_rf        = cm_rf_vals[1, 0]\n",
    "\n",
    "# --- PASO 2: Tabla comparativa de métricas ---\n",
    "# Se construye una tabla con todas las métricas de ambos modelos\n",
    "# para facilitar la comparación y justificar la selección del modelo final.\n",
    "# Incluir tanto métricas globales (Accuracy, AUC) como métricas específicas (Falsos Positivos, Falsos Negativos) permite\n",
    "# una evaluación completa desde distintos ángulos:\n",
    "# - Accuracy  --> rendimiento general\n",
    "# - F1-Score  --> equilibrio entre precision y recall (métrica principal)\n",
    "# - AUC-ROC   --> capacidad discriminatoria global\n",
    "# - Precision --> fiabilidad de las alarmas generadas\n",
    "# - Recall    --> cobertura de abandonos reales detectados\n",
    "# - FP y FN   --> impacto práctico en un sistema de alertas real\n",
    "comparativa = pd.DataFrame({\n",
    "    'Métrica': ['Accuracy', 'F1-Score', 'AUC-ROC',\n",
    "                'Precision', 'Recall',\n",
    "                'Falsos Positivos', 'Falsos Negativos'],\n",
    "    # Valores calculados dinámicamente en el paso 1\n",
    "    # nunca hardcodeados — se actualizan solos si se reentrena\n",
    "    'Regresión Logística': [\n",
