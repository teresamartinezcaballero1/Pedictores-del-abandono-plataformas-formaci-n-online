    "# annot=perfil[vars_cluster].round(1) --> muestra los valores reales dentro de cada celda (no los normalizados)\n",
    "# así el lector ve el color comparativo Y el número exacto\n",
    "# fmt='g' --> formato numérico general sin notación científica\n",
    "# cmap='Blues' --> escala de azules: más oscuro = valor más alto\n",
    "# linewidths=0.5 --> líneas finas entre celdas para legibilidad\n",
    "\n",
    "sns.heatmap(perfil_norm,\n",
