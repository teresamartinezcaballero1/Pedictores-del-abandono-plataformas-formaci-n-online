    "# ============================================================\n",
    "# CELDA 10: VARIABLES DERIVADAS DE NOTAS\n",
    "# ============================================================\n",
    "\n",
    "print(\"CREACIÓN DE VARIABLES DERIVADAS DE NOTAS\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "#Confirma cuántos registros tiene la tabla de notas\n",
    "print(f\"Registros studentAssessment enriquecido: {len(studentAssessment_enriquecido):,}\")\n",
    "#Lista las variables disponibles.\n",
    "print(f\"Variables disponibles: {list(studentAssessment_enriquecido.columns)}\")\n",
    "\n",
    "# =============================================================\n",
    "# INTERPOLACIÓN DE NOTAS FALTANTES EN SECUENCIA TEMPORAL\n",
    "# =============================================================\n",
    "\n",
    "print(\"\\n--- INTERPOLACIÓN DE NOTAS FALTANTES ---\")\n",
    "\n",
    "# Justificación: Algunos estudiantes tienen notas en algunas evaluaciones pero no en todas las de su secuencia. \n",
    "#La interpolación lineal estima las notas faltantes basándose en las evaluaciones anterior y posterior, asumiendo una progresión lineal del rendimiento académico a lo largo del tiempo. \n",
    "#Solo se aplica a TMA y CMA, no a exámenes (is_exam=0).\n",
    "\n",
    "# Paso 1: Ordenar por estudiante, módulo, presentación y fecha de entrega para que la interpolación respete el orden cronológico\n",
    "\n",
    "studentAssessment_interp = studentAssessment_enriquecido.copy()\n",
    "#Ordena los registros cronológicamente por estudiante y módulo\n",
    "studentAssessment_interp = studentAssessment_interp.sort_values(\n",
    "    by=['id_student', 'code_module', 'code_presentation', 'date_submitted']\n",
    ")\n",
    "\n",
    "# Paso 2: Separar evaluaciones continuas (TMA y CMA) de exámenes\n",
    "# La interpolación solo tiene sentido en evaluaciones continuas porque forman una secuencia temporal. \n",
    "#El examen es un evento único.\n",
    "#.copy()-->Para que los cambios que hagas en eval_continua no afecten a la tabla original studentAssessment_interp \n",
    "eval_continua = studentAssessment_interp[\n",
    "    studentAssessment_interp['is_exam'] == 0\n",
    "].copy()\n",
    "\n",
    "examenes = studentAssessment_interp[\n",
    "    studentAssessment_interp['is_exam'] == 1\n",
    "].copy()\n",
    "\n",
    "# Paso 3: Aplicar interpolación lineal dentro de cada grupo\n",
    "# (estudiante + módulo + presentación)\n",
    "# limit_direction='forward' solo interpola hacia adelante para no inventar notas antes de la primera entrega real\n",
    "# limit=2 limita la interpolación a máximo 2 evaluaciones consecutivas para no extrapolar demasiado lejos de los datos reales\n",
    "\n",
    "#Cuenta los nulos antes de interpolar para poder comparar después y saber cuántas notas se han estimado.\n",
    "nulos_antes = eval_continua['score'].isnull().sum()\n",
    "\n",
    "#Agrupa por estudiante y módulo para que la interpolación se haga dentro de cada estudiante por separado. \n",
    "#.transform--> Aplica la interpolación a cada grupo. Devuelve el resultado en el mismo formato que la tabla original, manteniendo todas las filas.\n",
    "#method='linear' -->Usa interpolación lineal — estima el valor faltante como el punto medio entre el anterior y el posterior.\n",
    "\n",
    "eval_continua['score'] = eval_continua.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['score'].transform(\n",
    "    lambda x: x.interpolate(method='linear', limit=2, limit_direction='forward')\n",
    ")\n",
    "\n",
    "nulos_despues = eval_continua['score'].isnull().sum()\n",
    "\n",
    "print(f\" Interpolación aplicada a evaluaciones continuas (TMA y CMA):\")\n",
    "print(f\"   Nulos antes de interpolación: {nulos_antes:,}\")\n",
    "print(f\"   Nulos después de interpolación: {nulos_despues:,}\")\n",
    "print(f\"   Notas estimadas por interpolación: {nulos_antes - nulos_despues:,}\")\n",
    "\n",
    "# Paso 4: Reunir evaluaciones continuas interpoladas con exámenes\n",
    "#concat--> une tablas verticalmente (añade filas)\n",
    "#ignore_index=True reinicia la numeración de filas desde 0 para que no haya índices duplicados tras la unión.\n",
    "#.sort--> vuelve a ordenar cronológicamente por estudiante y módulo\n",
    "#Después de concat--> las filas quedan desordenadas\n",
    "studentAssessment_interp = pd.concat(\n",
    "    [eval_continua, examenes], ignore_index=True\n",
    ").sort_values(\n",
    "    by=['id_student', 'code_module', 'code_presentation', 'date_submitted']\n",
    ")\n",
    "\n",
    "#Confirma que el número de registros es el mismo que antes de separar.\n",
    "print(f\"\\n   Registros tras interpolación: {len(studentAssessment_interp):,}\")\n",
    "#Confirma cuántos nulos quedan después de la interpolación\n",
    "#No serán 0 porque limit=2 no interpola todos los casos \n",
    "print(f\"   Nulos restantes en score: {studentAssessment_interp['score'].isnull().sum()}\")\n",
    "\n",
    "# =============================================================\n",
    "# VARIABLES GENERALES DE RENDIMIENTO ACADÉMICO\n",
    "# =============================================================\n",
    "\n",
    "# A partir de aquí usamos studentAssessment_interp en vez de\n",
    "# studentAssessment_enriquecido para que las medias incorporen\n",
    "# las notas estimadas por interpolación\n",
    "\n",
    "# --- VARIABLE 1: avg_score ---\n",
    "#Agrupa por estudiante y módulo\n",
    "#Calcula la media de todas las notas de ese estudiante\n",
    "#.reset_index()--> convierte el resultado en tabla normal\n",
    "#Usamos studentAssessment_interp porque es la versión con las notas interpoladas\n",
    "#Aunque no ha habido cambios en la interpolación porque había 0 nulos, siempre es mejor la última versión\n",
    "avg_score = studentAssessment_interp.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['score'].mean().reset_index()\n",
    "avg_score.columns = ['id_student', 'code_module', 'code_presentation', 'avg_score']\n",
    "avg_score['avg_score'] = avg_score['avg_score'].round(2)\n",
    "print(f\"\\n VARIABLE 1 — avg_score:\")\n",
    "#Nota media global de todos los estudiantes\n",
    "print(f\"   Media: {avg_score['avg_score'].mean():.2f}\")\n",
    "# Estudiante con peor rendimiento medio\n",
    "print(f\"   Mínimo: {avg_score['avg_score'].min():.2f}\")\n",
    "#Estudiante con mejor rendimiento medio, debería ser cercano a 100\n",
    "print(f\"   Máximo: {avg_score['avg_score'].max():.2f}\")\n",
    "\n",
    "# --- VARIABLE 2: avg_score_tma \n",
    "#Nota media sólo de los TMA (Trabajos corregidos por el tutor)\n",
    "tma_scores = studentAssessment_interp[\n",
    "    studentAssessment_interp['assessment_type'] == 'TMA'\n",
    "]\n",
    "avg_score_tma = tma_scores.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['score'].mean().reset_index()\n",
    "avg_score_tma.columns = ['id_student', 'code_module', 'code_presentation', 'avg_score_tma']\n",
    "avg_score_tma['avg_score_tma'] = avg_score_tma['avg_score_tma'].round(2)\n",
    "print(f\"\\n VARIABLE 2 — avg_score_tma:\")\n",
    "print(f\"   Media: {avg_score_tma['avg_score_tma'].mean():.2f}\")\n",
    "print(f\"   Estudiantes con TMA: {len(avg_score_tma):,}\")\n",
    "\n",
    "# --- VARIABLE 3: avg_score_cma \n",
    "#Media de computer marked assessment\n",
    "cma_scores = studentAssessment_interp[\n",
    "    studentAssessment_interp['assessment_type'] == 'CMA'\n",
    "]\n",
    "avg_score_cma = cma_scores.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['score'].mean().reset_index()\n",
    "avg_score_cma.columns = ['id_student', 'code_module', 'code_presentation', 'avg_score_cma']\n",
    "avg_score_cma['avg_score_cma'] = avg_score_cma['avg_score_cma'].round(2)\n",
    "print(f\"\\n VARIABLE 3 — avg_score_cma:\")\n",
    "print(f\"   Media: {avg_score_cma['avg_score_cma'].mean():.2f}\")\n",
    "print(f\"   Estudiantes con CMA: {len(avg_score_cma):,}\")\n",
    "\n",
    "# --- VARIABLE 4: num_assessments_submitted \n",
    "#Cuenta el número total de evaluaciones que ha entregado cada estudiante\n",
    "num_submitted = studentAssessment_interp.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['id_assessment'].count().reset_index()\n",
    "num_submitted.columns = ['id_student', 'code_module', 'code_presentation', 'num_assessments_submitted']\n",
    "print(f\"\\n VARIABLE 4 — num_assessments_submitted:\")\n",
    "#El número medio de evaluaciones entregadas por estudiante\n",
    "print(f\"   Media: {num_submitted['num_assessments_submitted'].mean():.1f} entregas por estudiante\")\n",
    "#El estudiante que menos evaluaciones entregó\n",
    "print(f\"   Mínimo: {num_submitted['num_assessments_submitted'].min()}\")\n",
    "#El estudiante que más evaluaciones entregó\n",
    "print(f\"   Máximo: {num_submitted['num_assessments_submitted'].max()}\")\n",
    "\n",
    "# --- VARIABLE 5: submitted_exam \n",
    "#Filtra sólo las filas de exámenes finales\n",
    "#Cuenta cuántos exámenes tiene cada estudiante\n",
    "#Cuando sólo hay un examen por módulo--> resultado=1 si se presentó\n",
    "#exam_submitted['submitted_exam'] = 1-->sustituye el conteo por simplemente 1.\n",
    "# Todos los estudiantes que aparecen en esta tabla se presentaron al examen, así que todos tienen valor 1.\n",
    "#Los que no se presentaron no aparecen porque no tienen is_exam=1\n",
    "exam_submitted = studentAssessment_interp[\n",
    "    studentAssessment_interp['is_exam'] == 1\n",
    "].groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['id_assessment'].count().reset_index()\n",
    "exam_submitted.columns = ['id_student', 'code_module', 'code_presentation', 'submitted_exam']\n",
    "exam_submitted['submitted_exam'] = 1\n",
    "print(f\"\\n VARIABLE 5 — submitted_exam:\")\n",
    "print(f\"   Estudiantes que se presentaron al examen: {len(exam_submitted):,}\")\n",
    "\n",
    "# --- VARIABLE 6: avg_submission_delay \n",
    "#Calcula el retraso medio de cada estudiante en sus entregas respecto a la fecha límite\n",
    "#Une las notas con assessment para añadir la fecha límite (date) de cada evaluación\n",
    "\n",
    "delay_data = studentAssessment_interp.merge(\n",
    "    assessments[['id_assessment', 'date']],\n",
    "    on='id_assessment',\n",
    "    how='left'\n",
    ")\n",
    "# Si el resultado es negativo significa que entregó antes de la fecha límite\n",
    "#Si es positivo--> entregó tarde\n",
    "delay_data['submission_delay'] = delay_data['date_submitted'] - delay_data['date']\n",
    "\n",
    "#Excluye las evaluaciones sin fecha (las que imputamos con 999 en la celda 7)\n",
    "delay_data_filtered = delay_data[delay_data['date'] != 999]\n",
    "#Calcula la media del retraso por estudiante y módulo.\n",
    "avg_delay = delay_data_filtered.groupby(\n",
    "    ['id_student', 'code_module', 'code_presentation']\n",
    ")['submission_delay'].mean().reset_index()\n",
    "avg_delay.columns = ['id_student', 'code_module', 'code_presentation', 'avg_submission_delay']\n",
    "avg_delay['avg_submission_delay'] = avg_delay['avg_submission_delay'].round(2)\n",
    "print(f\"\\n VARIABLE 6 — avg_submission_delay:\")\n",
    "#El retraso medio global. Si es positivo significa que de media los estudiantes entregan tarde.\n",
    "print(f\"   Media: {avg_delay['avg_submission_delay'].mean():.2f} días\")\n",
    "print(f\"   % que entrega tarde (delay > 0): {(avg_delay['avg_submission_delay'] > 0).mean()*100:.1f}%\")\n",
    "\n",
    "# =============================================================\n",
    "# INTEGRACIÓN DE TODAS LAS VARIABLES DE NOTAS\n",
    "# =============================================================\n",
    "\n",
    "print(\"\\nIntegrando variables de notas...\")\n",
    "\n",
    "#how='left'-->conservas todos los estudiantes aunque no tengan dato en alguna variable\n",
    "assessment_features = avg_score.merge(\n",
    "    avg_score_tma, on=['id_student', 'code_module', 'code_presentation'], how='left'\n",
    ").merge(\n",
    "    avg_score_cma, on=['id_student', 'code_module', 'code_presentation'], how='left'\n",
    ").merge(\n",
    "    num_submitted, on=['id_student', 'code_module', 'code_presentation'], how='left'\n",
    ").merge(\n",
    "    exam_submitted, on=['id_student', 'code_module', 'code_presentation'], how='left'\n",
    ").merge(\n",
    "    avg_delay, on=['id_student', 'code_module', 'code_presentation'], how='left'\n",
    ")\n",
    "\n",
    "print(\"Nulos antes del tratamiento:\")\n",
    "print(assessment_features.isnull().sum())\n",
    "\n",
    "# submitted_exam: rellenar con 0 los que no se presentaron\n",
    "#.fillna(0) los convierte en 0\n",
    "#.astype(int) los convierte a número entero porque submitted_exam es una variable binaria 0/1 \n",
    "assessment_features['submitted_exam'] = assessment_features['submitted_exam'].fillna(0).astype(int)\n",
    "\n",
    "# Tratamiento de nulos restantes tras interpolación\n",
    "# Los nulos que quedan en avg_score_tma y avg_score_cma son estudiantes de módulos que no tienen ese tipo de evaluación (nulos estructurales)\n",
    "# Se imputan con -1 como centinela-->No se usa 0 porque 0 es una nota real \n",
    "assessment_features['avg_score_tma'] = assessment_features['avg_score_tma'].fillna(-1)\n",
    "assessment_features['avg_score_cma'] = assessment_features['avg_score_cma'].fillna(-1)\n",
    "#El único nulo de retraso se imputa con 0, que significa que ese estudiante no tiene retrasos registrados.\n",
    "assessment_features['avg_submission_delay'] = assessment_features['avg_submission_delay'].fillna(0)\n",
    "\n",
    "# --- RESUMEN FINAL ---\n",
    "print(f\"\\n RESUMEN VARIABLES DERIVADAS DE NOTAS:\")\n",
    "#Confirma cuántos estudiantes hay en la tabla.\n",
    "print(f\"   Estudiantes únicos: {len(assessment_features):,}\")\n",
    "#Cuántas variables hay y cuáles son.\n",
    "print(f\"   Variables creadas: {len(assessment_features.columns)}\")\n",
    "#Confirma que después del tratamiento no quedan nulos. Debería salir 0 en todas las variables.\n",
    "print(f\"   Variables: {list(assessment_features.columns)}\")\n",
    "print(f\"   Nulos restantes: {assessment_features.isnull().sum().sum()}\")\n",
    "print(f\"\\n   Detalle de nulos por variable:\")\n",
    "print(assessment_features.isnull().sum())\n",
