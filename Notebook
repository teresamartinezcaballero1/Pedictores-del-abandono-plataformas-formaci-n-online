    "for v in variables_excluidas:\n",
    "    print(f'  x {v}')\n",
    "print(f'Variables finales: {len(vars_modelo_final)}')\n",
    "\n",
    "# --- PASO 2: Dataset limpio ---\n",
    "# Se construye la matriz X con solo las variables válidas (sin las excluidas por leakage del paso anterior)\n",
    "X_modelo = X_v2[vars_modelo_final]\n",
    "y_modelo  = base_modelo[target]\n",
    "\n",
    "# División train/test — mismos parámetros que en celdas anteriores\n",
    "# para garantizar que los mismos estudiantes van a train y a test\n",
    "# y los resultados sean comparables entre modelos\n",
    "X_train_m, X_test_m, y_train_m, y_test_m = train_test_split(\n",
    "    X_modelo, y_modelo,\n",
    "    test_size=0.2,      # 20% para test \n",
    "    random_state=42,    # misma semilla → misma división → comparación justa\n",
    "    stratify=y_modelo   # mantiene 31,5% de abandono en train y test\n",
    ")\n",
    "print(f'\\nTrain: {X_train_m.shape[0]:,} | Test: {X_test_m.shape[0]:,}')\n",
    "\n",
    "# Escalado específico para Regresión Logística\n",
    "# Se crea un scaler nuevo (scaler_m) independiente del de K-Means para no mezclar los parámetros de escalado entre modelos\n",
    "# fit_transform sobre train--> aprende media y desviación del train\n",
    "# transform sobre test--> aplica los mismos parámetros sin recalcular\n",
    "scaler_m         = StandardScaler()\n",
    "X_train_m_scaled = scaler_m.fit_transform(X_train_m)\n",
    "X_test_m_scaled  = scaler_m.transform(X_test_m)\n",
    "\n",
    "# --- PASO 3: Entrenar ---\n",
    "# LogisticRegression calcula la probabilidad de abandono usando una ecuación lineal con un peso por cada variable.\n",
    "# Durante el entrenamiento ajusta esos pesos para minimizar los errores sobre los datos de train.\n",
    "\n",
    "# max_iter=1000--> número máximo de iteraciones para encontrar los pesos óptimos. \n",
    "#El valor por defecto (100) a veces no es suficiente con datasets grandes — se aumenta a 1000 para\n",
    "# garantizar que el algoritmo converge correctamente.\n",
    "# random_state=42--> reproducibilidad\n",
    "rl = LogisticRegression(max_iter=1000, random_state=42)\n",
    "\n",
    "# fit--> el modelo aprende los pesos de cada variable usando SOLO los datos de train (nunca ve el test)\n",
    "rl.fit(X_train_m_scaled, y_train_m)\n",
    "\n",
    "# --- PASO 4: Métricas ---\n",
    "# predict--> aplica el modelo entrenado sobre el test\n",
    "# devuelve la clase predicha: 0 (no abandona) o 1 (abandona)\n",
    "y_pred_rl = rl.predict(X_test_m_scaled)\n",
    "\n",
    "# predict_proba--> devuelve la PROBABILIDAD de cada clase\n",
    "# [:, 1] coge solo la probabilidad de abandono (clase 1)\n",
    "# Esta probabilidad es necesaria para calcular AUC-ROC\n",
    "y_prob_rl = rl.predict_proba(X_test_m_scaled)[:, 1]\n",
    "\n",
    "# Se calculan las tres métricas principales\n",
    "acc_rl = accuracy_score(y_test_m, y_pred_rl)  # % total de aciertos\n",
    "f1_rl  = f1_score(y_test_m, y_pred_rl)        # métrica principal\n",
    "auc_rl = roc_auc_score(y_test_m, y_prob_rl)   # capacidad discriminatoria\n",
    "\n",
    "print(f'\\nMÉTRICAS — REGRESIÓN LOGÍSTICA')\n",
    "print('=' * 50)\n",
    "print(f'  Accuracy:  {acc_rl*100:.2f}%')\n",
    "print(f'  F1-Score:  {f1_rl:.4f}')\n",
    "print(f'  AUC-ROC:   {auc_rl:.4f}')\n",
    "\n",
    "# classification_report muestra precision, recall y F1 desglosados por clase (No abandona y Abandona)\n",
    "# target_names asigna nombres legibles a las clases 0 y 1\n",
    "print(classification_report(y_test_m, y_pred_rl,\n",
    "      target_names=['No abandona', 'Abandona']))\n",
    "\n",
    "# --- GRÁFICO 1: Matriz de confusión ---\n",
    "# La matriz de confusión muestra los 4 tipos de predicciones que puede hacer el modelo sobre los 6.297 estudiantes del test:\n",
    "## La matriz se evalúa sobre los 6.297 estudiantes del test —el 20% reservado en train_test_split que el modelo\n",
    "# nunca vio durante el entrenamiento, garantizando que las métricas reflejan el rendimiento real con datos nuevos\n",
    "\n",
    "\n",
    "#                    Pred: No abandona  |  Pred: Abandona\n",
    "# Real: No abandona  Verdadero Negativo |  Falso Positivo\n",
    "# Real: Abandona     Falso Negativo     |  Verdadero Positivo\n",
    "\n",
    "\n",
    "# Verdadero Negativo --> predijo que no abandona y tenía razón \n",
    "# Verdadero Positivo --> predijo que abandona y tenía razón    \n",
    "# Falso Positivo     --> predijo abandono pero no abandonó (alarma falsa)\n",
    "# Falso Negativo     --> predijo que no abandona pero sí lo hizo (el más peligroso)\n",
    "\n",
    "# En un sistema de alerta el Falso Negativo es el error más grave:\n",
    "# un estudiante en riesgo que el modelo no detecta y no recibe ayuda\n",
    "cm_rl = confusion_matrix(y_test_m, y_pred_rl)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "\n",
    "# annot=True --> muestra los números dentro de cada celda\n",
    "# fmt='d'    --> formato entero (sin decimales)\n",
    "# cmap='Blues' --> más azul = más estudiantes en esa celda\n",
    "sns.heatmap(cm_rl, annot=True, fmt='d', cmap='Blues',\n",
    "            xticklabels=['Pred: No abandona', 'Pred: Abandona'],\n",
    "            yticklabels=['Real: No abandona', 'Real: Abandona'],\n",
    "            ax=ax)\n",
    "ax.set_title('Matriz de confusión — Regresión Logística',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_ylabel('Valor real')\n",
    "ax.set_xlabel('Predicción del modelo')\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_confusion_rl.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# --- GRÁFICO 2: Curva ROC ---\n",
    "# La curva ROC muestra la capacidad discriminatoria del modelo probando todos los posibles umbrales de clasificación.\n",
    "# Por defecto el modelo predice abandono si la probabilidad > 0.5 pero ese umbral se puede cambiar según las necesidades:\n",
    "# - umbral bajo--> detecta más abandonos pero más falsas alarmas\n",
    "# - umbral alto--> menos falsas alarmas pero detecta menos abandonos\n",
    "# La curva ROC muestra el equilibrio entre ambos para cada umbral posible\n",
    "\n",
    "# roc_curve calcula los puntos de la curva:\n",
    "# fpr--> tasa de falsos positivos en cada umbral (eje X)\n",
    "# tpr-->tasa de verdaderos positivos en cada umbral (eje Y)\n",
    "# _   --> los umbrales (no se necesitan para el gráfico)\n",
    "fpr_rl, tpr_rl, _ = roc_curve(y_test_m, y_prob_rl)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "\n",
    "# Curva del modelo — cuanto más arriba a la izquierda mejor\n",
    "ax.plot(fpr_rl, tpr_rl, color='steelblue', linewidth=2.5,\n",
    "        label=f'Regresión Logística (AUC = {auc_rl:.3f})')\n",
    "\n",
    "# Línea diagonal gris --> modelo aleatorio que adivina al azar\n",
    "# Un buen modelo debe estar muy por encima de esta línea\n",
    "# Si la curva estuviera sobre la diagonal el modelo no serviría de nada\n",
    "ax.plot([0,1],[0,1], color='gray', linestyle='--',\n",
    "        linewidth=1.5, label='Modelo aleatorio (AUC = 0.500)')\n",
    "\n",
    "# Relleno bajo la curva para visualizar el área AUC\n",
    "ax.fill_between(fpr_rl, tpr_rl, alpha=0.1, color='steelblue')\n",
    "ax.set_title('Curva ROC — Regresión Logística',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Tasa de Falsos Positivos')\n",
    "ax.set_ylabel('Tasa de Verdaderos Positivos')\n",
    "ax.legend(loc='lower right')\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_roc_rl.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# --- GRÁFICO 3: Coeficientes top 15 ---\n",
    "# La Regresión Logística asigna un coeficiente a cada variable que indica su influencia sobre la probabilidad de abandono:\n",
    "# Coeficiente positivo --> esa variable AUMENTA el riesgo de abandono\n",
    "# Coeficiente negativo --> esa variable REDUCE el riesgo de abandono\n",
    "# Coeficiente cercano a 0 --> esa variable apenas influye\n",
    "\n",
    "# rl.coef_[0] --> array con el coeficiente de cada variable\n",
    "# Se ordena por valor absoluto para ver las 15 más influyentes independientemente de si aumentan o reducen el abandono\n",
    "coef_df = pd.DataFrame({\n",
    "    'Variable': vars_modelo_final,\n",
    "    'Coeficiente': rl.coef_[0]\n",
    "}).sort_values('Coeficiente', key=abs, ascending=False).head(15)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 7))\n",
    "\n",
    "# Rojo → coeficiente positivo → aumenta el riesgo de abandono\n",
    "# Azul → coeficiente negativo → reduce el riesgo de abandono\n",
    "colores = ['tomato' if c > 0 else 'steelblue'\n",
    "           for c in coef_df['Coeficiente']]\n",
    "\n",
    "# Gráfico horizontal para que los nombres de variables se lean bien\n",
    "ax.barh(coef_df['Variable'], coef_df['Coeficiente'],\n",
    "        color=colores, alpha=0.85, edgecolor='none')\n",
    "\n",
    "# Línea vertical en 0 para separar variables que aumentan el riesgo de las que lo reducen\n",
    "ax.axvline(x=0, color='black', linewidth=1)\n",
    "ax.set_title('Top 15 variables — Regresión Logística\\n'\n",
    "             '(rojo = aumenta abandono | azul = reduce abandono)',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Coeficiente')\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_coeficientes_rl.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print('\\nRegresión Logística completada ')"
