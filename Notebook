    "# Por ejemplo entre dos estudiantes:\n",
    "#   Estudiante A: 500 clics, 30 días, nota 60\n",
    "#   Estudiante B: 490 clics, 32 días, nota 58\n",
    "# -->están cerca--> mismo cluster\n",
    "#   Estudiante C: 5000 clics, 150 días, nota 90\n",
    "# --> está lejos de A y B--> cluster distinto\n",
    "\n",
    "# ¿Por qué no se usan variables categóricas?\n",
    "# Porque las distancias euclídeas no tienen sentido con texto.\n",
    "# La \"distancia\" entre género=M y género=F no es un concepto matemáticamente válido para este algoritmo.\n",
    "# Tampoco tiene sentido decir que la región 0 está más cerca de la región 1 que de la región 5 — son etiquetas, no valores.\n",
    "\n",
    "# ¿Por qué se excluye activity_span?\n",
    "# Porque usa last_activity_day — el día del último acceso.\n",
    "# Ese dato solo existe cuando el estudiante deja de conectarse, es decir al final del curso o cuando ya abandonó.\n",
    "# Incluirlo sería leakage: estaríamos usando información que en un sistema real no estaría disponible.\n",
    "\n",
    "\n",
    "# Variables seleccionadas — todas disponibles durante el curso:\n",
    "vars_cluster = [\n",
    "    'total_clicks',              # volumen total de actividad digital\n",
    "    'active_days',               # regularidad del estudio\n",
    "    'avg_score',                 # rendimiento académico general\n",
    "    'num_assessments_submitted', # compromiso con las entregas\n",
    "    'avg_submission_delay',      # puntualidad en las entregas\n",
    "    'submitted_exam',            # si se presentó al examen final\n",
    "    'avg_clicks_per_day'         # intensidad diaria del estudio\n",
    "]\n",
    "\n",
    "# Se trabaja sobre una copia de la base original para no modificar los datos en ningún paso posterior\n",
    "X_cluster = base[vars_cluster].copy()\n",
    "\n",
    "# --- PASO 2: Escalado ---\n",
    "# Mismo principio que en la celda 17: sin escalar, total_clicks\n",
    "# (hasta 24.139) dominaría frente a submitted_exam (0 o 1)\n",
    "# y los grupos no reflejarían diferencias reales de comportamiento.\n",
    "# A diferencia de la celda 17, aquí se aplica fit_transform sobre TODOS los datos porque K-Means no predice sino que\n",
    "# describe grupos — no existe train/test ni riesgo de leakage.\n",
    "scaler_cluster = StandardScaler()\n",
    "X_cluster_scaled = scaler_cluster.fit_transform(X_cluster)\n",
    "\n",
    "# --- PASO 3: Gráfico del codo para elegir k óptimo ---\n",
    "# Antes de aplicar K-Means hay que decidir cuántos grupos (k) crear.\n",
    "# No existe un número \"correcto\" predefinido — hay que encontrarlo.\n",
    "# El método del codo prueba distintos valores de k y mide la inercia\n",
    "# de cada uno para identificar el punto óptimo.\n",
    "\n",
    "# La inercia mide qué tan compactos son los clusters: es la suma de las distancias de cada estudiante a su centroide.\n",
    "# (El centroide es el \"estudiante medio\" de cada grupo)\n",
    "# Cuanto menor es la inercia, más parecidos son los estudiantes dentro de cada grupo — pero con más k siempre baja la inercia.\n",
    "# El truco es encontrar el k donde la mejora empieza a ser marginal.\n",
    "inercias = []\n",
    "rango_k = range(2, 10)  # probamos k desde 2 hasta 9\n",
    "\n",
    "for k in rango_k:\n",
    "    km = KMeans(\n",
    "        n_clusters=k,    # número de grupos a crear\n",
    "        random_state=42, # semilla para reproducibilidad\n",
    "        n_init=10        # repite el algoritmo 10 veces con distintos\n",
    "                         # puntos de inicio y se queda con el mejor\n",
    "    )\n",
    "    km.fit(X_cluster_scaled)\n",
    "    inercias.append(km.inertia_) # guarda la inercia de este k\n",
    "\n",
    "# Dibuja la curva de inercia para cada k\n",
    "# El \"codo\" visual es el punto donde la curva deja de bajar bruscamente\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "ax.plot(rango_k, inercias, 'o-', color='steelblue',\n",
    "        linewidth=2.5, markersize=8)\n",
    "ax.set_title('Método del codo — selección del número óptimo de clusters',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Número de clusters (k)')\n",
    "ax.set_ylabel('Inercia (suma de distancias al centroide)')\n",
    "\n",
    "# Línea vertical roja que marca el k elegido\n",
    "ax.axvline(x=4, color='tomato', linestyle='--',\n",
    "           linewidth=1.5, label='k=4 seleccionado')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_codo_kmeans.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# Justificación cuantitativa de k=4\n",
    "# En lugar de elegir k \"a ojo\" en el gráfico, calculamos\n",
    "# el descenso exacto de inercia entre cada par de k consecutivos\n",
    "# El descenso grande--> vale la pena añadir ese cluster\n",
    "# El descenso pequeño--> ese cluster extra no aporta casi nada\n",
    "print('JUSTIFICACIÓN DE k=4')\n",
    "print('=' * 40)\n",
    "for i in range(1, len(inercias)):\n",
    "    descenso = inercias[i-1] - inercias[i]\n",
    "    print(f'  k={i+2}: descenso de inercia = {descenso:.0f}')\n",
    "print('→ A partir de k=5 el descenso es marginal.')\n",
    "print('→ k=4 es el punto de equilibrio entre simplicidad y calidad.')\n",
    "\n",
    "# --- PASO 4: Modelo K-Means con k=4 ---\n",
    "# Se entrena el modelo final con k=4, el valor justificado\n",
    "# en el paso anterior mediante el método del codo\n",
    "km_final = KMeans(\n",
    "    n_clusters=4,    # 4 grupos — justificado por el método del codo\n",
    "    random_state=42, # reproducibilidad\n",
    "    n_init=10        # 10 intentos con distintos puntos de inicio\n",
    ")\n",
    "\n",
    "# fit_predict hace dos cosas a la vez:\n",
    "# fit--> encuentra los 4 centroides óptimos en los datos escalados\n",
    "# predict--> asigna a cada estudiante el cluster más cercano (0, 1, 2 o 3)\n",
    "# El resultado es un número del 0 al 3 para cada estudiante que se guarda directamente como nueva columna en base\n",
    "base['cluster'] = km_final.fit_predict(X_cluster_scaled)\n",
    "\n",
    "# Muestra cuántos estudiantes hay en cada cluster para verificar que los grupos tienen tamaños razonables\n",
    "# Si un cluster tuviera 3 estudiantes y otro 31.000 el modelo no habría encontrado grupos útiles\n",
    "print('DISTRIBUCIÓN DE ESTUDIANTES POR CLUSTER')\n",
    "print('=' * 50)\n",
    "dist = base['cluster'].value_counts().sort_index()\n",
    "for cluster, n in dist.items():\n",
    "    print(f'  Cluster {cluster}: {n:,} estudiantes ({n/len(base)*100:.1f}%)')\n",
    "\n",
    "# --- PASO 5: Perfil de cada cluster ---\n",
    "# Una vez asignados los clusters, calculamos el perfil medio de cada grupo \n",
    "# para entender qué tipo de estudiante representa cada cluster.\n",
    "# groupby('cluster')--> agrupa los 31.482 estudiantes por su cluster\n",
    "# .mean()--> calcula la media de cada variable dentro de cada grupo\n",
    "# Incluimos target_withdrawal para ver la tasa de abandono real de cada cluster — esto es el hallazgo más importante\n",
    "print('\\nPERFIL MEDIO DE CADA CLUSTER')\n",
    "print('=' * 50)\n",
    "perfil = base.groupby('cluster')[\n",
    "    vars_cluster + ['target_withdrawal']\n",
