    "# ============================================================\n",
    "# CELDA 4: VISUALIZACIONES DEL ESTADO INICIAL (ANTES)\n",
    "# ============================================================\n",
    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "print(\"ANÁLISIS DEL ESTADO INICIAL DE LOS DATOS\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# --- NORMALIZACIÓN PREVIA: estandarizar etiquetas de imd_band ---> todos los valores de imd_band deben terminar en %\n",
    "studentInfo['imd_band'] = studentInfo['imd_band'].apply(\n",
    "    lambda x: x.strip() + '%' if isinstance(x, str) and not x.strip().endswith('%') else x\n",
    ")\n",
    "\n",
    "# =============================================================\n",
    "# GRÁFICO 1: Valores nulos por archivo\n",
    "# =============================================================\n",
    "archivos_con_nulos = {\n",
    "    \"studentInfo\":         studentInfo,\n",
    "    \"studentRegistration\": studentRegistration,\n",
    "    \"studentAssessment\":   studentAssessment,\n",
    "    \"assessments\":         assessments,\n",
    "    \"vle\":                 vle\n",
    "}\n",
    "\n",
    "# Solo archivos que realmente tienen nulos\n",
    "archivos_filtrados = {\n",
    "    nombre: df for nombre, df in archivos_con_nulos.items()\n",
    "    if df.isnull().sum().sum() > 0\n",
    "}\n",
    "\n",
    "n = len(archivos_filtrados)\n",
    "fig, axes = plt.subplots(1, n, figsize=(5 * n, 6))\n",
    "fig.suptitle('Estado inicial de los datos: Valores nulos por archivo',\n",
    "             fontsize=16, fontweight='bold')\n",
    "\n",
    "#Recorre cada archivo con nulos \n",
    "for idx, (nombre, df) in enumerate(archivos_filtrados.items()):\n",
    "    #Selecciona el subgráfico correspondiente a ese archivo\n",
    "    ax = axes[idx]\n",
    "    #Calcula el porcentaje de nulos de cada columna.\n",
    "    nulos_pct = (df.isnull().sum() / len(df) * 100).round(2)\n",
    "    #Se queda solo con las columnas que tienen nulos y las ordena de mayor a menor.\n",
    "    nulos_pct = nulos_pct[nulos_pct > 0].sort_values(ascending=False)\n",
    "\n",
    "    bars = ax.bar(nulos_pct.index, nulos_pct.values, color='steelblue', width=0.5)\n",
    "    ax.set_title(nombre, fontweight='bold', fontsize=13)\n",
    "    ax.set_ylabel('% de valores nulos', fontsize=11)\n",
    "    ax.tick_params(axis='x', rotation=20)\n",
    "    ax.set_ylim(0, nulos_pct.values.max() * 1.2)\n",
    "\n",
    "    #Escribe el porcentaje encima de cada barra\n",
    "    for bar, val in zip(bars, nulos_pct.values):\n",
    "        ax.text(bar.get_x() + bar.get_width() / 2., bar.get_height(),\n",
    "                f'{val}%', ha='center', va='bottom', fontweight='bold', fontsize=11)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_nulos_antes.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\" Gráfico 1 guardado: grafico_nulos_antes.png\")\n",
    "\n",
    "\n",
    "# =============================================================\n",
    "# GRÁFICO 2: Distribución del resultado final\n",
    "# =============================================================\n",
    "orden_resultado = ['Distinction', 'Pass', 'Fail', 'Withdrawn']\n",
    "colores_resultado = {\n",
    "    'Distinction': 'steelblue',\n",
    "    'Pass':        'mediumseagreen',\n",
    "    'Fail':        'orange',\n",
    "    'Withdrawn':   'tomato'\n",
    "}\n",
    "\n",
    "#Para saber cuántos estudiantes hay en cada categoría y ordenarlos en el orden de arriba (.reindex)\n",
    "conteo = studentInfo['final_result'].value_counts().reindex(orden_resultado)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "bars = ax.bar(conteo.index,\n",
    "              conteo.values,\n",
    "              color=[colores_resultado[r] for r in conteo.index])\n",
    "\n",
    "ax.set_title('Distribución del resultado final (Estado inicial)',\n",
    "             fontweight='bold', fontsize=14)\n",
    "ax.set_xlabel('Resultado final', fontsize=12)\n",
    "ax.set_ylabel('Número de estudiantes', fontsize=12)\n",
    "ax.set_ylim(0, conteo.max() * 1.12)\n",
    "\n",
    "#Escribir el número y el porcentaje encima de cada barra\n",
    "for bar, val in zip(bars, conteo.values):\n",
    "    ax.text(bar.get_x() + bar.get_width() / 2., bar.get_height(),\n",
    "            f'{val:,}\\n({val / len(studentInfo) * 100:.1f}%)',\n",
    "            ha='center', va='bottom', fontweight='bold', fontsize=11)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('grafico_resultado_antes.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\" Gráfico 2 guardado: grafico_resultado_antes.png\")\n",
    "\n",
    "\n",
    "# =============================================================\n",
    "# GRÁFICO 3: Distribución IMD band\n",
    "# =============================================================\n",
    "#Cuenta cuántos estudiantes hay en cada banda IMD. \n",
    "#El dropna=False es importante: sin él los nulos se ignorarían y no aparecerían en el gráfico. \n",
    "#Aquí queremos verlos precisamente para mostrar el problema.\n",
    "imd_conteo = studentInfo['imd_band'].value_counts(dropna=False)\n",
    "\n",
    "# Separar nulos del resto--> en que posicion del índice es un nulo\n",
    "nan_mask = imd_conteo.index.isna()\n",
    "#Se queda solo con los valores que NO son nulos. \n",
    "#El ~ significa \"lo contrario de\".\n",
    "imd_sin_nan = imd_conteo[~nan_mask]\n",
    "#Guarda el número de nulos, si no hay, guarda 0\n",
    "nan_val = int(imd_conteo[nan_mask].values[0]) if nan_mask.any() else 0\n",
    "\n",
    "# Ordenar por el número inicial del rango (robusto ante cualquier formato)\n",
    "imd_sin_nan = imd_sin_nan.reindex(\n",
    "    sorted(imd_sin_nan.index,\n",
    "           key=lambda x: int(str(x).replace('%', '').strip().split('-')[0]))\n",
    ")\n",
    "\n",
    "# Unir: deciles ordenados + nan al final\n",
    "# Así los nulos aparecen como última barra \n",
    "imd_final = pd.concat([\n",
    "    imd_sin_nan,\n",
    "    pd.Series([nan_val], index=['nan'])\n",
    "])\n",
    "\n",
    "#Asignar colores a las barras\n",
    "# Los nulos se muestran en rojo para distinguir visualmente el problema\n",
    "colores_imd = ['tomato' if str(x) == 'nan' else 'steelblue' for x in imd_final.index]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(13, 6))\n",
    "\n",
    "#.astype(str)--> convierte el índice a texto para que matplotlib pueda mostrarlo correctamente en el eje X.\n",
    "bars = ax.bar(imd_final.index.astype(str), imd_final.values, color=colores_imd)\n",
    "\n",
    "ax.set_title('Distribución de IMD band (Estado inicial - incluye nulos)',\n",
    "             fontweight='bold', fontsize=14)\n",
    "ax.set_xlabel('IMD Band', fontsize=12)\n",
    "ax.set_ylabel('Número de estudiantes', fontsize=12)\n",
    "\n",
    "#Rotar las etiquetas para que no se solapen\n",
    "ax.tick_params(axis='x', rotation=30)\n",
    "ax.set_ylim(0, imd_final.max() * 1.12)\n",
    "\n",
    "for bar, val in zip(bars, imd_final.values):\n",
    "    ax.text(bar.get_x() + bar.get_width() / 2., bar.get_height(),\n",
    "            f'{val:,}', ha='center', va='bottom', fontweight='bold', fontsize=11)\n",
    "\n",
    "#Ajustar los espacios entre los elementos del gráfico para evitar que se solapen y corten\n",
    "plt.tight_layout()\n",
    "#Para guardar el gráfico\n",
    "plt.savefig('grafico_imd_antes.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\" Gráfico 3 guardado: grafico_imd_antes.png\")\n",
    "\n",
    "\n",
    "# =============================================================\n",
    "# RESUMEN NUMÉRICO\n",
    "# =============================================================\n",
    "print(\"\\n RESUMEN NUMÉRICO DEL ESTADO INICIAL:\")\n",
    "#Recorrer los 5 archivos e imprimir cuántos valores nulos tiene en total\n",
    "for nombre, df in archivos_con_nulos.items():\n",
    "    print(f\"   {nombre}: {df.isnull().sum().sum()} valores nulos totales\")\n"
   ]
